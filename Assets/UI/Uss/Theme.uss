}

#timer-pill .clock-icon {
    left: 12px;
    top: 11px;
    width: 84px;
    height: 84px;
    border-radius: 42px;
    border-width: 5px;
    border-bottom-width: 7px;
}

.clock-icon__face {
    width: 62px;
    height: 62px;
    border-radius: 31px;
    border-width: 4px;
}

.clock-icon__tick {
    width: 5px;
    height: 10px;
}

.clock-icon__tick--top {
