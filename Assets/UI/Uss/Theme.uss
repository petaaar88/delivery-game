}

/* ============================================================
   Main menu final reference pass
   ============================================================ */

.menu-top-row {
    left: 24px;
    top: 22px;
    right: 30px;
}

.top-pill {
    width: 164px;
    min-height: 74px;
    padding: 12px 18px;
    border-radius: 26px;
    background-color: rgba(244, 248, 252, 0.96);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.86);
    border-bottom-width: 6px;
    border-bottom-color: rgba(88, 82, 73, 0.22);
}

.top-pill Label {
    -unity-font-definition: url("../Fonts/Baloo2-ExtraBold.ttf");
    font-size: 30px;
    color: rgb(71, 55, 45);
    margin-left: 14px;
    -unity-text-outline-width: 0;
}

.soft-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background-color: rgb(255, 197, 61);
    border-width: 0;
    border-bottom-width: 0;
    align-items: center;
    justify-content: center;
}

.soft-icon--star {
    border-radius: 12px;
}

.coin-star {
    position: absolute;
    background-color: rgb(91, 67, 36);
    border-radius: 2px;
}

.coin-star--top {
    width: 6px;
    height: 12px;
    left: 19px;
    top: 9px;
}

.coin-star--right {
    width: 12px;
    height: 6px;
    left: 23px;
    top: 19px;
}

.coin-star--bottom {
    width: 6px;
    height: 12px;
    left: 19px;
    top: 23px;
}

.coin-star--left {
    width: 12px;
    height: 6px;
    left: 9px;
    top: 19px;
}

.coin-star--center {
    width: 10px;
    height: 10px;
    left: 17px;
    top: 17px;
    border-radius: 3px;
}

.icon-btn {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    background-color: rgb(255, 255, 255);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.8);
    border-bottom-width: 7px;
    border-bottom-color: rgba(111, 77, 39, 0.18);
    align-items: center;
    justify-content: center;
}

.settings-icon-btn {
    width: 128px;
    height: 128px;
    border-radius: 34px;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.88);
    border-bottom-width: 12px;
    border-bottom-color: rgba(111, 77, 39, 0.20);
}

.gear-icon {
    width: 76px;
    height: 76px;
    border-radius: 0;
    border-width: 0;
    align-items: center;
    justify-content: center;
}

.gear-tooth {
    position: absolute;
    width: 16px;
    height: 16px;
    border-radius: 3px;
    background-color: var(--warm-ink);
}

.gear-tooth--top {
    top: 4px;
    left: 30px;
    width: 16px;
    height: 20px;
}

.gear-tooth--right {
    right: 4px;
    top: 30px;
    width: 20px;
    height: 16px;
}

.gear-tooth--bottom {
    bottom: 4px;
    left: 30px;
    width: 16px;
    height: 20px;
}

.gear-tooth--left {
    left: 4px;
    top: 30px;
    width: 20px;
    height: 16px;
}

.gear-tooth--top-right {
    right: 12px;
    top: 12px;
    rotate: 45deg;
}

.gear-tooth--bottom-right {
    right: 12px;
    bottom: 12px;
    rotate: -45deg;
}

.gear-tooth--bottom-left {
    left: 12px;
    bottom: 12px;
    rotate: 45deg;
}

.gear-tooth--top-left {
    left: 12px;
    top: 12px;
    rotate: -45deg;
}

.gear-body {
    position: absolute;
    left: 16px;
    top: 16px;
    width: 44px;
    height: 44px;
    border-radius: 17px;
    background-color: var(--warm-ink);
    align-items: center;
    justify-content: center;
}

.gear-hole {
    width: 18px;
    height: 18px;
    border-radius: 7px;
    background-color: rgb(255, 255, 255);
}

.title-card {
    top: 40px;
    width: 360px;
}

.eyebrow {
    width: 300px;
    min-height: 42px;
    padding: 8px 18px;
    margin-bottom: 0;
    border-radius: 10px;
    background-color: rgb(244, 246, 250);
    color: rgb(123, 78, 45);
    font-size: 16px;
    -unity-text-outline-width: 0;
}

#game-title,
#game-subtitle {
    display: none;
}

#menu-buttons {
    right: 30px;
    bottom: 48px;
    width: 660px;
    flex-direction: column;
}

#menu-buttons .btn {
    margin-bottom: 0;
    -unity-text-outline-width: 0;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.82);
}

.button-depth {
    position: relative;
    align-self: flex-end;
    margin-bottom: 24px;
    transition-property: scale;
    transition-duration: 0.08s;
}

.button-depth:hover {
    scale: 1.02 1.02;
}

.button-depth:active {
    scale: 0.98 0.98;
}

.button-depth:active #play-button,
.button-depth:active #quit-button {
    translate: 0 8px;
}

.button-depth .btn,
.button-depth .icon-btn,
.button-depth #pause-button {
    position: absolute;
    left: 0;
    top: 0;
    margin-bottom: 0;
    transition-property: translate;
    transition-duration: 0.08s;
}

.button-depth .btn:hover:enabled,
.button-depth .icon-btn:hover:enabled,
.button-depth #pause-button:hover:enabled {
    scale: 1 1;
}

.button-depth .btn:active:enabled,
.button-depth .icon-btn:active:enabled,
.button-depth #pause-button:active:enabled {
    scale: 1 1;
    translate: 0 8px;
}

.button-depth__shadow {
    position: absolute;
    left: 0;
    right: 0;
}

.button-depth--settings {
    width: 128px;
    height: 140px;
    margin-bottom: 0;
}

.button-depth__shadow--settings {
    top: 12px;
    height: 128px;
    border-radius: 34px;
    background-color: rgb(220, 225, 233);
}

.button-depth--settings .settings-icon-btn {
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.62);
}

.button-depth--pause {
    width: 58px;
    height: 66px;
    align-self: auto;
    margin-right: 12px;
    margin-bottom: 0;
}

.button-depth__shadow--pause {
    top: 8px;
    height: 58px;
    border-radius: 16px;
    background-color: rgb(48, 34, 24);
}

.button-depth--pause #pause-button {
    width: 58px;
    height: 58px;
    margin-right: 0;
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.18);
}

.button-depth--card {
    align-self: stretch;
    height: 76px;
    margin-bottom: 14px;
}

.button-depth--card .btn {
    right: 0;
    width: auto;
    height: 64px;
    min-height: 64px;
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.58);
}

.button-depth--card .button-depth__shadow {
    top: 10px;
    height: 64px;
    border-radius: 18px;
}

.button-depth__shadow--green {
    background-color: rgb(70, 163, 70);
}

.button-depth__shadow--sky {
    background-color: rgb(74, 158, 204);
}

.button-depth__shadow--gold {
    background-color: rgb(224, 165, 38);
}

.button-depth__shadow--ghost {
    background-color: rgb(216, 220, 228);
}

.button-depth--play {
    width: 528px;
    height: 180px;
}

.button-depth__shadow--play {
    top: 24px;
    height: 156px;
    border-radius: 64px;
    background-color: rgb(72, 183, 72);
}

#play-button {
    position: absolute;
    left: 0;
    top: 0;
    width: 528px;
    height: 156px;
    min-height: 156px;
    border-radius: 64px;
    border-bottom-width: 2px;
    font-size: 109px;
    padding: 18px 44px;
    background-color: rgb(121, 216, 111);
    border-bottom-color: rgba(255, 255, 255, 0.62);
    color: white;
    transition-property: translate;
    transition-duration: 0.08s;
}

#play-button:hover:enabled,
#quit-button:hover:enabled {
    scale: 1 1;
}

#play-button:active:enabled,
#quit-button:active:enabled {
    scale: 1 1;
    translate: 0 8px;
}

.menu-secondary-row {
    display: none;
}

.button-depth--quit {
    width: 198px;
    height: 121px;
}

.button-depth__shadow--quit {
    top: 16px;
    height: 105px;
    border-radius: 42px;
    background-color: rgb(216, 220, 228);
}

#quit-button {
    position: absolute;
    left: 0;
    top: 0;
    width: 198px;
    height: 105px;
    min-height: 105px;
    border-radius: 42px;
    border-bottom-width: 2px;
    font-size: 53px;
    background-color: rgb(244, 246, 250);
    border-bottom-color: rgba(255, 255, 255, 0.62);
    color: rgb(91, 55, 33);
    transition-property: translate;
    transition-duration: 0.08s;
}

#menu-settings-overlay {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(19, 18, 26, 0.38);
    align-items: center;
    justify-content: center;
    display: none;
}

#menu-settings-overlay.overlay--show {
    display: flex;
}

#menu-settings-card {
    width: 500px;
    border-radius: 28px;
}

#version-label {
    right: 22px;
    bottom: 20px;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.92);
}

.btn,
.btn--green,
.btn--ghost,
.btn--sky,
.btn--gold {
    -unity-text-outline-width: 0;
}

.theme Label,
.theme Button {
    -unity-text-outline-width: 0;
}

/* ---------- global soft text/icon shadow pass ---------- */

.theme Label,
.theme Button {
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(47, 30, 15, 0.26);
}

#play-button {
    -unity-text-outline-width: 2px;
    -unity-text-outline-color: rgba(47, 30, 15, 0.28);
}

.btn--ghost,
.top-pill Label,
.eyebrow,
.settings-row__label {
    -unity-text-outline-color: rgba(255, 255, 255, 0.38);
}

.gear-tooth,
.gear-body,
.pause-bar,
.coin-star,
.coin-icon,
.soft-icon,
.clock-icon,
.package-icon {
    border-bottom-width: 2px;
    border-bottom-color: rgba(47, 30, 15, 0.26);
}

.gear-hole {
    border-bottom-width: 1px;
    border-bottom-color: rgba(47, 30, 15, 0.14);
}

/* ============================================================
   HUD polish pass — enlarged, kid-friendly, menu-consistent.
   Bigger touch-safe panels, animated speedo, softer text shadows.
   This is the last pass, so it wins the cascade over the earlier
   HUD rules above. Menu styling is intentionally left untouched.
   ============================================================ */

#safe-area {
    padding: 34px 44px;
}

#top-bar {
    min-height: 132px;
}

/* ---------- pause + coins (top-left) ---------- */

.button-depth--pause {
    width: 84px;
    height: 96px;
    margin-right: 18px;
}

.button-depth__shadow--pause {
    top: 10px;
    height: 84px;
    border-radius: 24px;
}

.button-depth--pause #pause-button {
    width: 84px;
    height: 84px;
    border-radius: 24px;
}

.pause-bar {
    width: 9px;
    height: 34px;
    border-radius: 4px;
    margin: 0 3px;
}

#coins-pill {
    min-width: 0;
    min-height: 84px;
    padding: 14px 28px 14px 16px;
    border-radius: 28px;
    border-bottom-width: 8px;
}

.coin-icon {
    width: 50px;
    height: 50px;
    border-radius: 16px;
    border-width: 0;
    border-bottom-width: 6px;
}

.coin-icon__inner {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    border-width: 4px;
}

.stat-pill Label {
    font-size: 44px;
    margin-left: 16px;
}

/* ---------- deliveries (top-center) ---------- */

.hud-progress {
    width: 380px;
    min-height: 84px;
    border-radius: 28px;
    padding: 14px 26px;
    border-bottom-width: 8px;
    justify-content: center;
}

.hud-progress-row {
    margin-bottom: 8px;
}

.hud-progress-row Label {
    font-size: 20px;
}

#deliveries-label {
    font-size: 24px;
    color: white;
}

.track {
    height: 14px;
    border-radius: 7px;
}

.track__fill {
    height: 14px;
    border-radius: 7px;
    transition-property: width;
    transition-duration: 0.45s;
    transition-timing-function: ease-out;
}

/* ---------- delivery card (top-right) ---------- */

#delivery-card {
    width: 470px;
    min-height: 128px;
    border-radius: 34px;
    padding: 20px 26px;
    border-bottom-width: 8px;
}

.package-icon--large {
    width: 76px;
    height: 76px;
    border-radius: 24px;
    border-bottom-width: 6px;
    margin-right: 18px;
}

.delivery-copy__eyebrow {
    font-size: 17px;
}

.delivery-copy__target {
    font-size: 32px;
    margin-top: 0;
}

#timer-label {
    font-size: 26px;
    margin-left: 10px;
    margin-right: 10px;
}

.clock-icon {
    width: 26px;
    height: 26px;
    border-radius: 9px;
}

.clock-icon__hand {
    width: 4px;
    height: 8px;
    translate: 0 -2px;
}

.timer-line,
.timer-line__fill {
    height: 9px;
    border-radius: 5px;
}

/* ---------- speedometer (bottom-left) ---------- */

#speed-panel {
    min-width: 330px;
    min-height: 144px;
    border-radius: 38px;
    padding: 16px 32px 16px 18px;
    border-bottom-width: 8px;
    align-items: center;
}

.gauge {
    width: 108px;
    height: 108px;
    border-radius: 54px;
    border-width: 9px;
    border-color: rgba(121, 216, 111, 0.95);
    background-color: rgba(20, 14, 10, 0.34);
    margin-right: 20px;
}

/* needle pivots from its base at the gauge centre; angle is driven
   from HudController each frame (see UpdateSpeed). */
.needle {
    position: absolute;
    left: 50%;
    bottom: 50%;
    width: 6px;
    height: 38px;
    margin-left: -3px;
    border-radius: 3px;
    background-color: rgb(255, 255, 255);
    translate: 0 0;
    rotate: -120deg;
    transform-origin: 50% 100%;
}

.gauge-hub {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 16px;
    height: 16px;
    margin-left: -8px;
    margin-top: -8px;
    border-radius: 8px;
    background-color: rgb(242, 246, 244);
    border-width: 3px;
    border-color: rgba(67, 47, 31, 0.55);
}

#speed-label {
    font-size: 78px;
    -unity-text-align: middle-left;
}

#speed-unit {
    font-size: 24px;
    margin-left: 10px;
    margin-bottom: 8px;
}

/* ---------- soft dark text shadow for legibility over the world ---------- */

#speed-label,
#banner,
#reward-toast {
    -unity-text-outline-width: 2px;
    -unity-text-outline-color: rgba(24, 16, 8, 0.55);
}

.stat-pill Label,
.delivery-copy__target,
#timer-label {
    -unity-text-outline-width: 1.5px;
    -unity-text-outline-color: rgba(24, 16, 8, 0.48);
}

.delivery-copy__eyebrow,
#speed-unit,
#deliveries-label,
.hud-progress-row Label {
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(24, 16, 8, 0.42);
}

/* ============================================================
   Kid-friendly refinement pass
   Flat solid panels (less gloss / no heavy transparency), a fixed
   speed panel that no longer resizes, gauge ticks + dynamic feel,
   and a shared coin badge used by both the HUD and the main menu.
   ============================================================ */

/* ---------- flat, solid panels ---------- */

#coins-pill,
#deliveries-pill,
#delivery-card,
#speed-panel {
    background-color: rgb(56, 69, 96);
    border-width: 0;
    border-bottom-width: 8px;
    border-bottom-color: rgb(37, 47, 71);
}

.button-depth--pause #pause-button {
    background-color: rgb(56, 69, 96);
    border-width: 0;
    border-bottom-width: 3px;
    border-bottom-color: rgba(255, 255, 255, 0.12);
}

.button-depth__shadow--pause {
    background-color: rgb(37, 47, 71);
}

.gauge {
    background-color: rgb(33, 41, 60);
}

/* ---------- speed panel: fixed size so digit count can't flicker it ---------- */

#speed-panel {
    width: 360px;
    min-width: 360px;
    justify-content: flex-start;
}

#speed-label {
    min-width: 118px;
    -unity-text-align: middle-right;
    transition-property: scale, color;
    transition-duration: 0.16s, 0.16s;
    transition-timing-function: ease-out;
}

/* high-speed pop: the number jumps and warms up (driven from C#) */
#speed-panel.speed--fast #speed-label {
    color: rgb(255, 238, 165);
    scale: 1.16 1.16;
}

#speed-panel.speed--fast .needle {
    background-color: rgb(255, 236, 150);
}

/* ---------- gauge tick marks ---------- */

.gauge-tick {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
}

.gauge-tick__mark {
    position: absolute;
    top: 2px;
    left: 50%;
    margin-left: -2px;
    width: 4px;
    height: 8px;
    border-radius: 2px;
    background-color: rgba(255, 255, 255, 0.5);
}

.gauge-tick--1 { rotate: -120deg; }
.gauge-tick--2 { rotate: -80deg; }
.gauge-tick--3 { rotate: -40deg; }
.gauge-tick--4 { rotate: 0deg; }
.gauge-tick--5 { rotate: 40deg; }
.gauge-tick--6 { rotate: 80deg; }
.gauge-tick--7 { rotate: 120deg; }

/* ============================================================
   Coin badge — shared reward icon (HUD + main menu, identical).
   Flat gold disc: outer rim, a 4-point star and a small shine.
   ============================================================ */

.coin-badge {
    width: 48px;
    height: 48px;
    border-radius: 24px;
    background-color: rgb(255, 201, 66);
    border-width: 0;
    border-bottom-width: 4px;
    border-bottom-color: rgb(214, 150, 33);
    align-items: center;
    justify-content: center;
}

.coin-badge__ring {
    position: absolute;
    left: 5px;
    top: 5px;
    right: 5px;
    bottom: 5px;
    border-radius: 19px;
    border-width: 3px;
    border-color: rgba(198, 138, 26, 0.55);
}

.coin-badge__ray {
    position: absolute;
    left: 50%;
    top: 50%;
    translate: -50% -50%;
    background-color: rgb(176, 116, 28);
    border-radius: 3px;
    border-bottom-width: 0;
}

.coin-badge__ray--v {
    width: 7px;
    height: 26px;
}

.coin-badge__ray--h {
    width: 26px;
    height: 7px;
}

.coin-badge__ray--core {
    width: 13px;
    height: 13px;
    rotate: 45deg;
    border-radius: 4px;
}

.coin-badge__glint {
    position: absolute;
    left: 8px;
    top: 7px;
    width: 9px;
    height: 9px;
    border-radius: 5px;
    background-color: rgba(255, 245, 214, 0.92);
}

/* ============================================================
   Whitish HUD pass — match the main-menu pills, kill the drab
   grey, polished candy depth, dark text, fixed gauge aspect,
   plus the confetti piece style.
   ============================================================ */

/* light candy panels with a clean chunky bottom ledge */
#coins-pill,
#deliveries-pill,
#delivery-card,
#speed-panel {
    background-color: rgb(245, 247, 251);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.9);
    border-bottom-width: 9px;
    border-bottom-color: rgb(213, 218, 227);
    border-radius: 28px;
}

/* pause: light icon button (face) over its own offset shadow */
.button-depth--pause #pause-button {
    background-color: rgb(245, 247, 251);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.9);
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.62);
}

.button-depth__shadow--pause {
    background-color: rgb(213, 218, 227);
}

.pause-bar {
    background-color: rgb(78, 62, 50);
}

/* warm dark text on the light panels (menu palette), no outline */
.stat-pill Label,
#speed-label,
.delivery-copy__target,
#deliveries-label,
#timer-label {
    color: rgb(71, 55, 45);
    -unity-text-outline-width: 0;
}

.delivery-copy__eyebrow,
#speed-unit,
.hud-progress-row Label {
    color: rgb(146, 120, 92);
    -unity-text-outline-width: 0;
}

#timer-pill.timer--low #timer-label {
    color: rgb(223, 91, 65);
}

/* tracks need a darker groove on the light panels */
.timer-line,
.track {
    background-color: rgba(71, 55, 45, 0.14);
}

/* gauge: stop it being flex-shrunk into an egg; recessed dark dial */
.gauge {
    flex-shrink: 0;
    background-color: rgb(38, 46, 66);
}

/* high-speed pop reads red on the light panel */
#speed-panel.speed--fast #speed-label {
    color: rgb(223, 91, 65);
    scale: 1.16 1.16;
}

/* ---------- confetti ---------- */

.confetti {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    opacity: 1;
    transition-property: translate, rotate, opacity;
    transition-duration: 0.95s, 0.95s, 0.95s;
    transition-timing-function: ease-out;
}

/* ============================================================
   Juice pass — sparks that fly out of their source element,
   elastic panel bounces, springier banner/toast entrances.
   Deliveries panel is parked (hidden) for now.
   ============================================================ */

#deliveries-pill {
    display: none;
}

/* spark streak: spawned at the centre of its origin element and
   rotated to point along its outward flight (see SpawnSparks). */
.spark {
    position: absolute;
    left: 50%;
    top: 50%;
    border-radius: 3px;
    opacity: 1;
    transition-property: translate, opacity, scale;
    transition-duration: 0.5s, 0.5s, 0.5s;
    transition-timing-function: ease-out, ease-out, ease-out;
}

/* elastic pop applied briefly from C# */
#speed-panel,
#coins-pill,
#delivery-card {
    transition-property: scale;
    transition-duration: 0.34s;
    transition-timing-function: ease-out-elastic;
}

.panel-pop {
    scale: 1.09 1.09;
}

/* springier banner entrance */
#banner {
    scale: 0.7 0.7;
    transition-duration: 0.3s, 0.3s;
    transition-timing-function: ease-out-back, ease-out-back;
}

/* reward toast pops in with a bounce too */
#reward-toast {
    scale: 0.6 0.6;
    transition-property: opacity, translate, scale;
    transition-duration: 0.3s, 0.3s, 0.3s;
    transition-timing-function: ease-out-back, ease-out-back, ease-out-back;
}

#reward-toast.toast--show {
    scale: 1 1;
}

/* ============================================================
   Main menu requested polish pass
   ============================================================ */

.title-card {
    display: none;
}

.menu-score-pill {
    min-width: 210px;
    min-height: 92px;
    width: auto;
    border-radius: 46px;
    padding: 12px 32px;
    background-color: rgb(245, 247, 251);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.9);
    border-bottom-width: 8px;
    border-bottom-color: rgb(213, 218, 227);
}

.menu-score-pill .coin-badge {
    width: 56px;
    height: 56px;
    border-radius: 28px;
}

.menu-score-pill Label {
    -unity-font-definition: url("../Fonts/Baloo2-ExtraBold.ttf");
    font-size: 53px;
    margin-left: 22px;
    color: rgb(91, 55, 33);
    -unity-text-outline-width: 0;
}

.button-depth__shadow--play {
    background-color: rgb(30, 190, 54);
}

#play-button {
    background-color: rgb(83, 224, 72);
}
