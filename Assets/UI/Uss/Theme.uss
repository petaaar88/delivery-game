    border-width: 2px;
    border-bottom-width: 3px;
}

.timer-line__divider {
    top: 3px;
    width: 4px;
    height: 12px;
}

/* ============================================================
   Timer lane fix
   Use absolute lanes inside the blue timer so the tall Kids
   Magazine glyphs cannot overlap the label or the progress bar.
   ============================================================ */

#timer-pill {
    width: 410px;
    height: 122px;
    min-height: 122px;
    padding: 10px 24px 10px 112px;
    border-radius: 30px;
}

#timer-pill .clock-icon {
    left: 12px;
    top: 14px;
    width: 86px;
    height: 86px;
    border-radius: 43px;
}

.clock-icon__face {
    width: 62px;
    height: 62px;
    border-radius: 31px;
}

.global-timer__copy {
    position: relative;
    height: 100px;
    flex-grow: 1;
    min-width: 0;
    justify-content: flex-start;
}

.global-timer__eyebrow {
    position: absolute;
    left: 0;
    right: 0;
    top: 1px;
    height: 14px;
    font-size: 10px;
    margin-bottom: 0;
    -unity-text-align: middle-center;
}

#timer-label {
    position: absolute;
    left: 0;
    right: 0;
    top: 27px;
    height: 44px;
    font-size: 40px;
    margin-top: 0;
    margin-bottom: 0;
    -unity-text-align: middle-center;
    translate: 0 0;
}

.timer-line {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 10px;
    width: auto;
    height: 19px;
    min-height: 19px;
    margin-top: 0;
}

.timer-line__fill {
    top: 3px;
    left: 3px;
    height: 11px;
    min-height: 11px;
}

.timer-line__divider {
    top: 4px;
    height: 11px;
}

/* ============================================================
   Text speedometer pass
   The dial is gone — the readout is a big number in a clean white
   pill (matches the HUD sections). HudController ramps its colour
   green -> amber -> red with speed and vibrates the whole pill
   around Z as it nears top speed (see UpdateSpeed). Fixed width so
   the digit count never reflows the layout.
   ============================================================ */

#speed-panel {
    position: relative;
    width: 216px;
    min-width: 216px;
    height: 168px;
    min-height: 168px;
    margin-left: 0;
    padding: 16px 22px 18px 22px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-image: none;
    background-color: rgb(245, 247, 251);
    border-width: 3px;
    border-color: rgba(255, 255, 255, 0.95);
    border-bottom-width: 9px;
    border-bottom-color: rgb(213, 218, 227);
    border-radius: 36px;
}

/* Fixed lane so a changing digit count never re-measures the label and
   nudges KM/H. Colour is overridden every frame from C#; this is the rest. */
#speed-panel #speed-label {
    position: relative;
    left: auto;
    top: auto;
    width: 100%;
    height: 96px;
    margin: 0;
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 66px;
    color: rgb(60, 165, 75);
    -unity-text-align: middle-center;
    -unity-text-outline-width: 0;
}

#speed-panel #speed-unit {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    height: 26px;
    font-size: 22px;
    letter-spacing: 0;
    color: rgb(146, 120, 92);
    -unity-text-align: middle-center;
    -unity-text-outline-width: 0;
    margin-top: 12px;
    margin-bottom: 0;
    margin-left: 0;
}

/* red-hot frame while flat out */
#speed-panel.speed--fast {
    border-color: rgb(255, 208, 202);
    border-bottom-color: rgb(223, 91, 65);
}

/* The whole pill pops (PopPanel .panel-pop) — the number must NOT scale on
   its own (older passes set scale:1.16 here), or it spills out of the pill. */
#speed-panel.speed--fast #speed-label {
    scale: 1 1;
}

/* ============================================================
   Clean HUD pass — match the main menu's sections + buttons.
   Everything becomes the light "candy" system: #F5F7FB panels
   with a white sticker border, a soft gray depth ledge, warm
   dark text and colored accent icons. Replaces the earlier blue
   arcade treatment. This is the last pass, so it wins the cascade.
   Layout lanes (fixed heights, absolute timer lanes) are kept.
   ============================================================ */

#safe-area {
    padding: 22px 32px;
}

#top-bar {
    min-height: 132px;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
}

/* ---------- top-left: pause button + coins pill, side by side ---------- */

#top-left {
    position: relative;
    width: auto;
    min-width: 0;
    height: 90px;
    min-height: 90px;
    padding: 0;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    border-radius: 0;
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
}

/* pause: chunky light icon button (menu icon-btn style) */
.button-depth--pause {
    position: relative;
    left: auto;
    top: auto;
    align-self: center;
    width: 88px;
    height: 90px;
    margin-right: 14px;
    margin-bottom: 0;
}

.button-depth__shadow--pause {
    top: 9px;
    height: 78px;
    border-radius: 26px;
    background-color: rgb(213, 218, 227);
}

.button-depth--pause #pause-button {
    width: 88px;
    height: 78px;
    border-radius: 26px;
    background-color: rgb(245, 247, 251);
    border-width: 3px;
    border-color: rgba(255, 255, 255, 0.95);
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.6);
}

.pause-bar {
    width: 9px;
    height: 32px;
    border-radius: 4px;
    margin: 0 4px;
    background-color: rgb(71, 55, 45);
}

/* coins: fully-round white pill with gold coin badge + dark number */
#coins-pill {
    width: auto;
    min-width: 150px;
    height: 84px;
    min-height: 84px;
    flex-grow: 0;
    flex-shrink: 0;
    padding: 8px 26px 8px 14px;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    background-color: rgb(245, 247, 251);
    border-width: 3px;
    border-color: rgba(255, 255, 255, 0.95);
    border-bottom-width: 9px;
    border-bottom-color: rgb(213, 218, 227);
    border-radius: 42px;
}

#coins-pill .coin-badge {
    width: 54px;
    height: 54px;
    margin-right: 12px;
    flex-shrink: 0;
}

#coins-label {
    min-width: 0;
    height: auto;
    font-size: 44px;
    letter-spacing: 0;
    color: rgb(71, 55, 45);
    margin-left: 0;
    -unity-text-align: middle-left;
    -unity-text-outline-width: 0;
}

/* ---------- top-right: global run timer as a white section ---------- */

#timer-pill {
    width: 420px;
    height: 122px;
    min-height: 122px;
    margin-left: auto;
    margin-right: 0;
    padding: 12px 26px 12px 114px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    background-color: rgb(245, 247, 251);
    border-width: 3px;
    border-color: rgba(255, 255, 255, 0.95);
    border-bottom-width: 9px;
    border-bottom-color: rgb(213, 218, 227);
    border-radius: 34px;
}

/* the clock stays a blue accent icon (like the menu's gold badges) */
#timer-pill .clock-icon {
    left: 14px;
    top: 15px;
    width: 88px;
    height: 88px;
    border-radius: 44px;
    background-color: rgb(54, 180, 239);
    border-width: 4px;
    border-color: white;
    border-bottom-width: 6px;
    border-bottom-color: rgb(0, 105, 177);
}

.global-timer__eyebrow {
    color: rgb(146, 120, 92);
    -unity-text-outline-width: 0;
}

#timer-label {
    color: rgb(71, 55, 45);
    -unity-text-outline-width: 0;
}

/* progress bar: light groove, gold fill */
.timer-line {
    background-color: rgb(224, 229, 237);
    border-width: 2px;
    border-color: rgb(210, 216, 226);
}

.timer-line__fill {
    background-color: rgb(255, 197, 61);
    border-color: rgb(255, 232, 150);
    border-bottom-color: rgb(224, 165, 38);
}

.timer-line__divider {
    background-color: rgb(213, 218, 227);
}

/* low-time warning: keep the white pill, turn text + fill coral */
#timer-pill.timer--low {
    background-color: rgb(245, 247, 251);
    border-color: rgba(255, 255, 255, 0.95);
    border-bottom-color: rgb(213, 218, 227);
}

#timer-pill.timer--low #timer-label,
#timer-pill.timer--low .global-timer__eyebrow {
    color: rgb(223, 91, 65);
    -unity-text-outline-width: 0;
}

#timer-pill.timer--low .clock-icon {
    background-color: rgb(255, 127, 99);
    border-bottom-color: rgb(223, 91, 65);
}

#timer-pill.timer--low .timer-line {
    background-color: rgb(247, 224, 221);
    border-color: rgb(240, 208, 204);
}

#timer-pill.timer--low .timer-line__fill {
    background-color: rgb(232, 72, 61);
    border-color: rgb(255, 158, 148);
    border-bottom-color: rgb(180, 42, 40);
}

/* ============================================================
   Unified coin pill component (shared: HUD + main menu)
   One capsule — gold coin badge + count — reused on both screens.
   Width is auto so it grows from a single digit to a multi-digit
   total; min-width keeps short values still reading as a pill.
   Base size is the in-game HUD; .coin-pill--menu scales the whole
   thing up (bigger badge + font) for the main menu. Last pass, so
   it wins the cascade over the per-screen rules above.
   ============================================================ */

#coins-pill,
.coin-pill {
    width: auto;
    min-width: 190px;
    height: 84px;
    min-height: 84px;
    flex-grow: 0;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 8px 34px 8px 22px;
    background-color: rgb(245, 247, 251);
    border-width: 3px;
    border-color: rgba(255, 255, 255, 0.95);
    border-bottom-width: 9px;
    border-bottom-color: rgb(213, 218, 227);
    border-radius: 46px;
}

#coins-pill .coin-badge,
.coin-pill .coin-badge {
    width: 54px;
    height: 54px;
    margin-right: 14px;
    flex-shrink: 0;
}

#coins-label,
.coin-pill__label {
    min-width: 0;
    height: auto;
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 44px;
    letter-spacing: 0;
    color: rgb(71, 55, 45);
    margin-left: 0;
    -unity-text-align: middle-left;
    -unity-text-outline-width: 0;
}

/* ---------- main menu: same capsule, scaled up ---------- */

.coin-pill--menu {
    min-width: 250px;
    height: 112px;
    min-height: 112px;
    padding: 10px 44px 10px 30px;
    border-bottom-width: 10px;
    border-radius: 60px;
}

.coin-pill--menu .coin-badge {
    width: 76px;
    height: 76px;
    margin-right: 20px;
}

.coin-pill--menu .coin-pill__label {
    font-size: 64px;
}

/* ============================================================
   Timer heartbeat pass
   The low-time pulse now scales the WHOLE pill (from C#), not the
   digits (which used to spill out). It's driven per-frame, so the
   pill's scale must be instant — the shared elastic scale
   transition would damp the pulse to nothing. Last pass, wins.
   ============================================================ */

#timer-pill {
    transition-property: scale;
    transition-duration: 0s;
    transform-origin: 50% 50%;
}

/* ============================================================
   Timer spacing pass
   The progress bar was jammed right under the digits. Give the
   pill a little more height and drop the bar into its own lane
   with clear air below the number. Absolute lanes inside
   .global-timer__copy: eyebrow (top), number, then the bar. Last
   pass, wins the cascade.
   ============================================================ */

#top-bar {
    min-height: 140px;
}

#timer-pill {
    height: 132px;
    min-height: 132px;
    padding: 10px 26px 10px 114px;
}

#timer-pill .clock-icon {
    top: 20px;
}

.global-timer__copy {
    height: 108px;
}

#timer-label {
    top: 20px;
}

.timer-line {
    top: 86px;
    bottom: auto;
}
