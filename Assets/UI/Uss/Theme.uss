    justify-content: center;
}

#coins-pill .coin-badge {
    width: 52px;
    height: 52px;
    margin-right: 14px;
}

#coins-label {
    font-size: 48px;
    -unity-text-outline-width: 4px;
    -unity-text-outline-color: rgb(17, 63, 135);
}

#timer-pill {
    width: 440px;
    height: 108px;
    min-height: 108px;
    margin-left: auto;
    margin-right: 0;
    padding: 10px 24px 10px 112px;
    border-radius: 29px;
    border-width: 5px;
    border-color: rgb(202, 243, 255);
    border-bottom-width: 8px;
    border-bottom-color: rgb(0, 95, 167);
