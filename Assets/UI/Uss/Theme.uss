}

.clock-icon__pin {
    width: 11px;
    height: 11px;
    margin-left: -5px;
    margin-top: -5px;
    border-radius: 6px;
}

.global-timer__copy {
    height: 86px;
}

.global-timer__eyebrow {
    font-size: 14px;
    margin-bottom: -8px;
}

#timer-label {
    font-size: 56px;
    margin-top: -5px;
    -unity-text-outline-width: 4px;
}

.timer-line {
    height: 22px;
    border-radius: 11px;
    margin-top: -6px;
    border-width: 3px;
}

.timer-line__fill {
    top: 2px;
    left: 2px;
    height: 16px;
    border-radius: 9px;
    border-width: 2px;
    border-bottom-width: 4px;
}

.timer-line__divider {
    top: 3px;
    width: 5px;
    height: 16px;
    border-radius: 3px;
}

#delivery-card {
    display: none;
}

/* ============================================================
   HUD polish correction pass
   Measured against Unity Play Mode screenshot: keep the panels
   compact but give every text row a fixed lane so nothing clips.
   ============================================================ */

#safe-area {
    padding: 14px 22px;
}

#top-bar {
    min-height: 118px;
    align-items: flex-start;
}

#top-left {
    width: 268px;
    height: 88px;
    min-height: 88px;
    padding: 8px 20px 8px 84px;
    border-radius: 27px;
    border-width: 5px;
    border-color: rgb(205, 244, 255);
    border-bottom-width: 8px;
    border-bottom-color: rgb(0, 91, 165);
    background-color: rgb(22, 162, 226);
}

.button-depth--pause {
    left: -3px;
    top: 4px;
    width: 82px;
    height: 84px;
}

.button-depth__shadow--pause {
    top: 9px;
    height: 72px;
    border-radius: 36px;
}

.button-depth--pause #pause-button {
    width: 72px;
    height: 72px;
    border-radius: 36px;
}

.pause-bar {
    width: 8px;
    height: 28px;
    margin: 0 4px;
}

#coins-pill {
    width: 156px;
    height: 64px;
    flex-grow: 0;
    justify-content: flex-start;
    align-items: center;
}

#coins-pill .coin-badge {
    width: 48px;
    height: 48px;
    margin-right: 13px;
}

#coins-label {
    min-width: 86px;
    height: 58px;
    font-size: 44px;
    -unity-text-align: middle-left;
    -unity-text-outline-width: 4px;
}

#timer-pill {
    width: 392px;
    height: 104px;
    min-height: 104px;
    margin-left: auto;
    margin-right: 0;
    padding: 8px 22px 10px 104px;
    border-radius: 28px;
    border-width: 5px;
    border-bottom-width: 8px;
}

#timer-pill .clock-icon {
    left: 11px;
    top: 10px;
    width: 80px;
    height: 80px;
    border-radius: 40px;
}

.clock-icon__face {
    width: 58px;
    height: 58px;
    border-radius: 29px;
}

.global-timer__copy {
    height: 84px;
    align-items: stretch;
    justify-content: center;
}

.global-timer__eyebrow {
    height: 16px;
    font-size: 13px;
    margin-bottom: -2px;
    -unity-text-align: middle-center;
}

#timer-label {
    height: 48px;
    font-size: 48px;
    margin-top: -2px;
    margin-bottom: -1px;
    -unity-text-align: middle-center;
    -unity-text-outline-width: 4px;
}

.timer-line {
    width: 100%;
    height: 18px;
    min-height: 18px;
    margin-top: 0;
    border-radius: 9px;
