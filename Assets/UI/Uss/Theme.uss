/* ============================================================
   Unified arcade UI lock
   Consistent rounded-rect system for menu, HUD, pause, controls.
   ============================================================ */

.btn,
.icon-btn,
#pause-button,
.touch-btn {
    transition-property: scale;
    transition-duration: 0.08s;
}

.btn {
    min-height: 64px;
    border-radius: 18px;
    border-bottom-width: 8px;
    padding: 10px 24px;
    -unity-font-definition: url("../Fonts/Baloo2-ExtraBold.ttf");
    font-size: 28px;
}

.btn:hover:enabled,
.icon-btn:hover:enabled,
#pause-button:hover:enabled {
    scale: 1.02 1.02;
}

.btn:active:enabled,
.icon-btn:active:enabled,
#pause-button:active:enabled {
    scale: 0.98 0.98;
    translate: 0 2px;
}

.pill,
.top-pill,
.hud-progress,
#delivery-card,
#speed-panel,
.menu-card {
    border-radius: 18px;
    background-color: var(--glass);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.18);
    border-bottom-width: 6px;
    border-bottom-color: rgba(47, 30, 15, 0.22);
}

#menu-root {
    background-color: rgba(0, 0, 0, 0);
    align-items: stretch;
    justify-content: flex-start;
}

.menu-vignette {
    background-color: rgba(45, 30, 17, 0.12);
}

.menu-top-row {
    left: 34px;
    top: 34px;
    right: 34px;
}

.top-pill {
    width: 166px;
    min-height: 70px;
    padding: 12px 18px;
}

.top-pill Label {
    font-size: 30px;
    color: white;
    margin-left: 12px;
}

.soft-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    border-bottom-width: 5px;
}

.soft-icon--star {
    border-radius: 12px;
}

.clock-icon {
    border-radius: 10px;
}

.icon-btn {
    width: 70px;
    height: 70px;
    border-radius: 18px;
    border-bottom-width: 6px;
}

.gear-icon {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    border-width: 7px;
}

.gear-icon__dot {
    width: 8px;
    height: 8px;
    border-radius: 3px;
}

.title-card {
    top: 60px;
    width: 700px;
}

.eyebrow {
    width: 360px;
    min-height: 46px;
    padding: 10px 22px;
    margin-bottom: 20px;
    border-radius: 14px;
    font-size: 18px;
}

#game-title {
    font-size: 96px;
    color: white;
    -unity-text-align: middle-center;
    -unity-text-outline-width: 0;
}

#game-subtitle {
    width: 360px;
