    flex-direction: column;
}

#menu-buttons .btn {
    margin-bottom: 18px;
}

#play-button {
    width: 460px;
    min-height: 96px;
    border-radius: 22px;
    border-bottom-width: 10px;
    font-size: 44px;
    padding: 16px 30px;
}

.menu-secondary-row {
    width: 460px;
