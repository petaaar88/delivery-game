/* ============================================================
   Main menu final reference pass
   ============================================================ */

.menu-top-row {
    left: 24px;
    top: 22px;
    right: 30px;
}

.top-pill {
    width: 164px;
    min-height: 74px;
    padding: 12px 18px;
    border-radius: 26px;
    background-color: rgba(244, 248, 252, 0.96);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.86);
    border-bottom-width: 6px;
    border-bottom-color: rgba(88, 82, 73, 0.22);
}

.top-pill Label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 30px;
    color: rgb(71, 55, 45);
    margin-left: 14px;
    -unity-text-outline-width: 0;
}

.soft-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background-color: rgb(255, 197, 61);
    border-width: 0;
    border-bottom-width: 0;
    align-items: center;
    justify-content: center;
}

.soft-icon--star {
    border-radius: 12px;
}

.coin-star {
    position: absolute;
    background-color: rgb(91, 67, 36);
    border-radius: 2px;
}

.coin-star--top {
    width: 6px;
    height: 12px;
    left: 19px;
    top: 9px;
}

.coin-star--right {
    width: 12px;
    height: 6px;
    left: 23px;
    top: 19px;
}

.coin-star--bottom {
    width: 6px;
    height: 12px;
    left: 19px;
    top: 23px;
}

.coin-star--left {
    width: 12px;
    height: 6px;
    left: 9px;
    top: 19px;
}

.coin-star--center {
    width: 10px;
    height: 10px;
    left: 17px;
    top: 17px;
    border-radius: 3px;
}

.icon-btn {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    background-color: rgb(255, 255, 255);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.8);
    border-bottom-width: 7px;
    border-bottom-color: rgba(111, 77, 39, 0.18);
    align-items: center;
    justify-content: center;
}

.settings-icon-btn {
    width: 128px;
    height: 128px;
    border-radius: 34px;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.88);
    border-bottom-width: 12px;
    border-bottom-color: rgba(111, 77, 39, 0.20);
}

.gear-icon {
    width: 76px;
    height: 76px;
    border-radius: 0;
    border-width: 0;
    align-items: center;
    justify-content: center;
}

.gear-tooth {
    position: absolute;
    width: 16px;
    height: 16px;
    border-radius: 3px;
    background-color: var(--warm-ink);
}

.gear-tooth--top {
    top: 4px;
    left: 30px;
    width: 16px;
    height: 20px;
}

.gear-tooth--right {
    right: 4px;
    top: 30px;
    width: 20px;
    height: 16px;
}

.gear-tooth--bottom {
    bottom: 4px;
    left: 30px;
    width: 16px;
    height: 20px;
}

.gear-tooth--left {
    left: 4px;
    top: 30px;
    width: 20px;
    height: 16px;
}

.gear-tooth--top-right {
    right: 12px;
    top: 12px;
    rotate: 45deg;
}

.gear-tooth--bottom-right {
    right: 12px;
    bottom: 12px;
    rotate: -45deg;
}

.gear-tooth--bottom-left {
    left: 12px;
    bottom: 12px;
    rotate: 45deg;
}

.gear-tooth--top-left {
    left: 12px;
    top: 12px;
    rotate: -45deg;
}

.gear-body {
    position: absolute;
    left: 16px;
    top: 16px;
    width: 44px;
    height: 44px;
    border-radius: 17px;
    background-color: var(--warm-ink);
    align-items: center;
    justify-content: center;
}

.gear-hole {
    width: 18px;
    height: 18px;
    border-radius: 7px;
    background-color: rgb(255, 255, 255);
}

.title-card {
    top: 40px;
    width: 360px;
}

.eyebrow {
    width: 300px;
    min-height: 42px;
    padding: 8px 18px;
    margin-bottom: 0;
    border-radius: 10px;
    background-color: rgb(244, 246, 250);
    color: rgb(123, 78, 45);
    font-size: 16px;
    -unity-text-outline-width: 0;
}

#game-title,
#game-subtitle {
    display: none;
}

#menu-buttons {
    right: 30px;
    bottom: 48px;
    width: 660px;
    flex-direction: column;
}

#menu-buttons .btn {
    margin-bottom: 0;
    -unity-text-outline-width: 0;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.82);
}

.button-depth {
    position: relative;
    align-self: flex-end;
    margin-bottom: 24px;
    transition-property: scale;
    transition-duration: 0.08s;
}

.button-depth:hover {
    scale: 1.02 1.02;
}

.button-depth:active {
    scale: 0.98 0.98;
}

.button-depth:active #play-button,
.button-depth:active #quit-button {
    translate: 0 8px;
}

.button-depth .btn,
.button-depth .icon-btn,
.button-depth #pause-button {
    position: absolute;
    left: 0;
    top: 0;
    margin-bottom: 0;
    transition-property: translate;
    transition-duration: 0.08s;
}

.button-depth .btn:hover:enabled,
.button-depth .icon-btn:hover:enabled,
.button-depth #pause-button:hover:enabled {
    scale: 1 1;
}

.button-depth .btn:active:enabled,
.button-depth .icon-btn:active:enabled,
.button-depth #pause-button:active:enabled {
    scale: 1 1;
    translate: 0 8px;
}

.button-depth__shadow {
    position: absolute;
    left: 0;
    right: 0;
}

.button-depth--settings {
    width: 128px;
    height: 140px;
    margin-bottom: 0;
}

.button-depth__shadow--settings {
    top: 12px;
    height: 128px;
    border-radius: 34px;
    background-color: rgb(220, 225, 233);
}

.button-depth--settings .settings-icon-btn {
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.62);
}

.button-depth--pause {
    width: 58px;
    height: 66px;
    align-self: auto;
    margin-right: 12px;
    margin-bottom: 0;
}

.button-depth__shadow--pause {
    top: 8px;
    height: 58px;
    border-radius: 16px;
    background-color: rgb(48, 34, 24);
}

.button-depth--pause #pause-button {
    width: 58px;
    height: 58px;
    margin-right: 0;
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.18);
}

.button-depth--card {
    align-self: stretch;
    height: 76px;
    margin-bottom: 14px;
}

.button-depth--card .btn {
    right: 0;
    width: auto;
    height: 64px;
    min-height: 64px;
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.58);
}

.button-depth--card .button-depth__shadow {
    top: 10px;
    height: 64px;
    border-radius: 18px;
}

.button-depth__shadow--green {
    background-color: rgb(70, 163, 70);
}

.button-depth__shadow--sky {
    background-color: rgb(74, 158, 204);
}

.button-depth__shadow--gold {
    background-color: rgb(224, 165, 38);
}

.button-depth__shadow--ghost {
    background-color: rgb(216, 220, 228);
}

.button-depth--play {
    width: 528px;
    height: 180px;
}

.button-depth__shadow--play {
    top: 24px;
    height: 156px;
    border-radius: 64px;
    background-color: rgb(72, 183, 72);
}

#play-button {
    position: absolute;
    left: 0;
    top: 0;
    width: 528px;
    height: 156px;
    min-height: 156px;
    border-radius: 64px;
    border-bottom-width: 2px;
    font-size: 109px;
    padding: 18px 44px;
    background-color: rgb(121, 216, 111);
    border-bottom-color: rgba(255, 255, 255, 0.62);
    color: white;
    transition-property: translate;
    transition-duration: 0.08s;
}

#play-button:hover:enabled,
#quit-button:hover:enabled {
    scale: 1 1;
}

#play-button:active:enabled,
#quit-button:active:enabled {
    scale: 1 1;
    translate: 0 8px;
}

.menu-secondary-row {
    display: none;
}

.button-depth--quit {
    width: 198px;
    height: 121px;
}

.button-depth__shadow--quit {
    top: 16px;
    height: 105px;
    border-radius: 42px;
    background-color: rgb(216, 220, 228);
}

#quit-button {
    position: absolute;
    left: 0;
    top: 0;
    width: 198px;
    height: 105px;
    min-height: 105px;
    border-radius: 42px;
    border-bottom-width: 2px;
    font-size: 53px;
    background-color: rgb(244, 246, 250);
    border-bottom-color: rgba(255, 255, 255, 0.62);
    color: rgb(91, 55, 33);
    transition-property: translate;
    transition-duration: 0.08s;
}

#menu-settings-overlay {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(19, 18, 26, 0.38);
    align-items: center;
    justify-content: center;
    display: none;
}

#menu-settings-overlay.overlay--show {
    display: flex;
}

#menu-settings-card {
    width: 500px;
    border-radius: 28px;
}

#version-label {
    right: 22px;
    bottom: 20px;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.92);
}

.btn,
.btn--green,
.btn--ghost,
.btn--sky,
.btn--gold {
    -unity-text-outline-width: 0;
}

.theme Label,
.theme Button {
    -unity-text-outline-width: 0;
}

/* ---------- global soft text/icon shadow pass ---------- */

.theme Label,
.theme Button {
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(47, 30, 15, 0.26);
}

#play-button {
    -unity-text-outline-width: 2px;
    -unity-text-outline-color: rgba(47, 30, 15, 0.28);
}

.btn--ghost,
.top-pill Label,
.eyebrow,
.settings-row__label {
    -unity-text-outline-color: rgba(255, 255, 255, 0.38);
}

.gear-tooth,
.gear-body,
.pause-bar,
.coin-star,
.coin-icon,
.soft-icon,
.clock-icon,
.package-icon {
    border-bottom-width: 2px;
    border-bottom-color: rgba(47, 30, 15, 0.26);
}

.gear-hole {
    border-bottom-width: 1px;
    border-bottom-color: rgba(47, 30, 15, 0.14);
}

/* ============================================================
   HUD polish pass — enlarged, kid-friendly, menu-consistent.
   Bigger touch-safe panels, animated speedo, softer text shadows.
   This is the last pass, so it wins the cascade over the earlier
   HUD rules above. Menu styling is intentionally left untouched.
   ============================================================ */

#safe-area {
    padding: 34px 44px;
}

#top-bar {
    min-height: 132px;
}

/* ---------- pause + coins (top-left) ---------- */

.button-depth--pause {
    width: 84px;
    height: 96px;
    margin-right: 18px;
}

.button-depth__shadow--pause {
    top: 10px;
    height: 84px;
    border-radius: 24px;
}

.button-depth--pause #pause-button {
    width: 84px;
    height: 84px;
    border-radius: 24px;
}

.pause-bar {
    width: 9px;
    height: 34px;
    border-radius: 4px;
    margin: 0 3px;
}

#coins-pill {
    min-width: 0;
    min-height: 84px;
    padding: 14px 28px 14px 16px;
    border-radius: 28px;
    border-bottom-width: 8px;
}

.coin-icon {
    width: 50px;
    height: 50px;
    border-radius: 16px;
    border-width: 0;
    border-bottom-width: 6px;
}

.coin-icon__inner {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    border-width: 4px;
}

.stat-pill Label {
    font-size: 44px;
    margin-left: 16px;
}

/* ---------- deliveries (top-center) ---------- */

.hud-progress {
    width: 380px;
    min-height: 84px;
    border-radius: 28px;
    padding: 14px 26px;
    border-bottom-width: 8px;
    justify-content: center;
}

.hud-progress-row {
    margin-bottom: 8px;
}

.hud-progress-row Label {
    font-size: 20px;
}

#deliveries-label {
    font-size: 24px;
    color: white;
}

.track {
    height: 14px;
    border-radius: 7px;
}

.track__fill {
    height: 14px;
    border-radius: 7px;
    transition-property: width;
    transition-duration: 0.45s;
    transition-timing-function: ease-out;
}

/* ---------- delivery card (top-right) ---------- */

#delivery-card {
    width: 470px;
    min-height: 128px;
    border-radius: 34px;
    padding: 20px 26px;
    border-bottom-width: 8px;
}

.package-icon--large {
    width: 76px;
    height: 76px;
    border-radius: 24px;
    border-bottom-width: 6px;
    margin-right: 18px;
}

.delivery-copy__eyebrow {
    font-size: 17px;
}

.delivery-copy__target {
    font-size: 32px;
    margin-top: 0;
}

#timer-label {
    font-size: 26px;
    margin-left: 10px;
    margin-right: 10px;
}

.clock-icon {
    width: 26px;
    height: 26px;
    border-radius: 9px;
}

.clock-icon__hand {
    width: 4px;
    height: 8px;
    translate: 0 -2px;
}

.timer-line,
.timer-line__fill {
    height: 9px;
    border-radius: 5px;
}

/* ---------- speedometer (bottom-left) ---------- */

#speed-panel {
    min-width: 330px;
    min-height: 144px;
    border-radius: 38px;
    padding: 16px 32px 16px 18px;
    border-bottom-width: 8px;
    align-items: center;
}

.gauge {
    width: 108px;
    height: 108px;
    border-radius: 54px;
    border-width: 9px;
    border-color: rgba(121, 216, 111, 0.95);
    background-color: rgba(20, 14, 10, 0.34);
    margin-right: 20px;
}

/* needle pivots from its base at the gauge centre; angle is driven
   from HudController each frame (see UpdateSpeed). */
.needle {
    position: absolute;
    left: 50%;
    bottom: 50%;
    width: 6px;
    height: 38px;
    margin-left: -3px;
    border-radius: 3px;
    background-color: rgb(255, 255, 255);
    translate: 0 0;
    rotate: -120deg;
    transform-origin: 50% 100%;
}

.gauge-hub {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 16px;
    height: 16px;
    margin-left: -8px;
    margin-top: -8px;
    border-radius: 8px;
    background-color: rgb(242, 246, 244);
    border-width: 3px;
    border-color: rgba(67, 47, 31, 0.55);
}

#speed-label {
    font-size: 78px;
    -unity-text-align: middle-left;
}

#speed-unit {
    font-size: 24px;
    margin-left: 10px;
    margin-bottom: 8px;
}

/* ---------- soft dark text shadow for legibility over the world ---------- */

#speed-label,
#banner,
#reward-toast {
    -unity-text-outline-width: 2px;
    -unity-text-outline-color: rgba(24, 16, 8, 0.55);
}

.stat-pill Label,
.delivery-copy__target,
#timer-label {
    -unity-text-outline-width: 1.5px;
    -unity-text-outline-color: rgba(24, 16, 8, 0.48);
}

.delivery-copy__eyebrow,
#speed-unit,
#deliveries-label,
.hud-progress-row Label {
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(24, 16, 8, 0.42);
}

/* ============================================================
   Kid-friendly refinement pass
   Flat solid panels (less gloss / no heavy transparency), a fixed
   speed panel that no longer resizes, gauge ticks + dynamic feel,
   and a shared coin badge used by both the HUD and the main menu.
   ============================================================ */

/* ---------- flat, solid panels ---------- */

#coins-pill,
#deliveries-pill,
#delivery-card,
#speed-panel {
    background-color: rgb(56, 69, 96);
    border-width: 0;
    border-bottom-width: 8px;
    border-bottom-color: rgb(37, 47, 71);
}

.button-depth--pause #pause-button {
    background-color: rgb(56, 69, 96);
    border-width: 0;
    border-bottom-width: 3px;
    border-bottom-color: rgba(255, 255, 255, 0.12);
}

.button-depth__shadow--pause {
    background-color: rgb(37, 47, 71);
}

.gauge {
    background-color: rgb(33, 41, 60);
}

/* ---------- speed panel: fixed size so digit count can't flicker it ---------- */

#speed-panel {
    width: 360px;
    min-width: 360px;
    justify-content: flex-start;
}

#speed-label {
    min-width: 118px;
    -unity-text-align: middle-right;
    transition-property: scale, color;
    transition-duration: 0.16s, 0.16s;
    transition-timing-function: ease-out;
}

/* high-speed pop: the number jumps and warms up (driven from C#) */
#speed-panel.speed--fast #speed-label {
    color: rgb(255, 238, 165);
    scale: 1.16 1.16;
}

#speed-panel.speed--fast .needle {
    background-color: rgb(255, 236, 150);
}

/* ---------- gauge tick marks ---------- */

.gauge-tick {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
}

.gauge-tick__mark {
    position: absolute;
    top: 2px;
    left: 50%;
    margin-left: -2px;
    width: 4px;
    height: 8px;
    border-radius: 2px;
    background-color: rgba(255, 255, 255, 0.5);
}

.gauge-tick--1 { rotate: -120deg; }
.gauge-tick--2 { rotate: -80deg; }
.gauge-tick--3 { rotate: -40deg; }
.gauge-tick--4 { rotate: 0deg; }
.gauge-tick--5 { rotate: 40deg; }
.gauge-tick--6 { rotate: 80deg; }
.gauge-tick--7 { rotate: 120deg; }

/* ============================================================
   Coin badge — shared reward icon (HUD + main menu, identical).
   Flat gold disc: outer rim, a 4-point star and a small shine.
   ============================================================ */

.coin-badge {
    width: 48px;
    height: 48px;
    border-radius: 24px;
    background-color: rgb(255, 201, 66);
    border-width: 0;
    border-bottom-width: 4px;
    border-bottom-color: rgb(214, 150, 33);
    align-items: center;
    justify-content: center;
}

.coin-badge__ring {
    position: absolute;
    left: 5px;
    top: 5px;
    right: 5px;
    bottom: 5px;
    border-radius: 19px;
    border-width: 3px;
    border-color: rgba(198, 138, 26, 0.55);
}

.coin-badge__ray {
    position: absolute;
    left: 50%;
    top: 50%;
    translate: -50% -50%;
    background-color: rgb(176, 116, 28);
    border-radius: 3px;
    border-bottom-width: 0;
}

.coin-badge__ray--v {
    width: 7px;
    height: 26px;
}

.coin-badge__ray--h {
    width: 26px;
    height: 7px;
}

.coin-badge__ray--core {
    width: 13px;
    height: 13px;
    rotate: 45deg;
    border-radius: 4px;
}

.coin-badge__glint {
    position: absolute;
    left: 8px;
    top: 7px;
    width: 9px;
    height: 9px;
    border-radius: 5px;
    background-color: rgba(255, 245, 214, 0.92);
}

/* ============================================================
   Whitish HUD pass — match the main-menu pills, kill the drab
   grey, polished candy depth, dark text, fixed gauge aspect,
   plus the confetti piece style.
   ============================================================ */

/* light candy panels with a clean chunky bottom ledge */
#coins-pill,
#deliveries-pill,
#delivery-card,
#speed-panel {
    background-color: rgb(245, 247, 251);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.9);
    border-bottom-width: 9px;
    border-bottom-color: rgb(213, 218, 227);
    border-radius: 28px;
}

/* pause: light icon button (face) over its own offset shadow */
.button-depth--pause #pause-button {
    background-color: rgb(245, 247, 251);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.9);
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.62);
}

.button-depth__shadow--pause {
    background-color: rgb(213, 218, 227);
}

.pause-bar {
    background-color: rgb(78, 62, 50);
}

/* warm dark text on the light panels (menu palette), no outline */
.stat-pill Label,
#speed-label,
.delivery-copy__target,
#deliveries-label,
#timer-label {
    color: rgb(71, 55, 45);
    -unity-text-outline-width: 0;
}

.delivery-copy__eyebrow,
#speed-unit,
.hud-progress-row Label {
    color: rgb(146, 120, 92);
    -unity-text-outline-width: 0;
}

#timer-pill.timer--low #timer-label {
    color: rgb(223, 91, 65);
}

/* tracks need a darker groove on the light panels */
.timer-line,
.track {
    background-color: rgba(71, 55, 45, 0.14);
}

/* gauge: stop it being flex-shrunk into an egg; recessed dark dial */
.gauge {
    flex-shrink: 0;
    background-color: rgb(38, 46, 66);
}

/* high-speed pop reads red on the light panel */
#speed-panel.speed--fast #speed-label {
    color: rgb(223, 91, 65);
    scale: 1.16 1.16;
}

/* ---------- confetti ---------- */

.confetti {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    opacity: 1;
    transition-property: translate, rotate, opacity;
    transition-duration: 0.95s, 0.95s, 0.95s;
    transition-timing-function: ease-out;
}

/* ============================================================
   Juice pass — sparks that fly out of their source element,
   elastic panel bounces, springier banner/toast entrances.
   Deliveries panel is parked (hidden) for now.
   ============================================================ */

#deliveries-pill {
    display: none;
}

/* spark streak: spawned at the centre of its origin element and
   rotated to point along its outward flight (see SpawnSparks). */
.spark {
    position: absolute;
    left: 50%;
    top: 50%;
    border-radius: 3px;
    opacity: 1;
    transition-property: translate, opacity, scale;
    transition-duration: 0.5s, 0.5s, 0.5s;
    transition-timing-function: ease-out, ease-out, ease-out;
}

/* elastic pop applied briefly from C# */
#speed-panel,
#coins-pill,
#delivery-card {
    transition-property: scale;
    transition-duration: 0.34s;
    transition-timing-function: ease-out-elastic;
}

.panel-pop {
    scale: 1.09 1.09;
}

/* springier banner entrance */
#banner {
    scale: 0.7 0.7;
    transition-duration: 0.3s, 0.3s;
    transition-timing-function: ease-out-back, ease-out-back;
}

/* reward toast pops in with a bounce too */
#reward-toast {
    scale: 0.6 0.6;
    transition-property: opacity, translate, scale;
    transition-duration: 0.3s, 0.3s, 0.3s;
    transition-timing-function: ease-out-back, ease-out-back, ease-out-back;
}

#reward-toast.toast--show {
    scale: 1 1;
}

/* ============================================================
   Main menu requested polish pass
   ============================================================ */

.title-card {
    display: none;
}

.button-depth__shadow--play {
    background-color: rgb(30, 190, 54);
}

#play-button {
    background-color: rgb(83, 224, 72);
}

/* ============================================================
   Global run timer pass
   ============================================================ */

#top-bar {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
}

#top-left,
#delivery-card,
#timer-pill {
    position: relative;
    top: auto;
    left: auto;
    right: auto;
    translate: 0 0;
}

#top-left,
#delivery-card {
    flex-shrink: 0;
}

#timer-pill {
    display: none;
    width: 330px;
    min-height: 86px;
    margin-left: 22px;
    margin-right: 22px;
    padding: 12px 20px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    background-color: rgb(245, 247, 251);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.9);
    border-bottom-width: 8px;
    border-bottom-color: rgb(213, 218, 227);
    border-radius: 28px;
}

#timer-pill.timer--visible {
    display: flex;
}

#timer-pill .clock-icon {
    width: 50px;
    height: 50px;
    border-radius: 16px;
    margin-right: 16px;
    flex-shrink: 0;
    background-color: rgb(115, 206, 255);
    border-width: 0;
    border-bottom-width: 6px;
    border-bottom-color: rgb(72, 172, 223);
}

#timer-pill .clock-icon__hand {
    width: 5px;
    height: 15px;
    border-radius: 3px;
    translate: 0 -4px;
}

.global-timer__copy {
    flex-grow: 1;
    min-width: 0;
    justify-content: center;
}

.global-timer__eyebrow {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 13px;
    color: rgb(146, 120, 92);
    -unity-text-outline-width: 0;
    margin-bottom: -6px;
}

#timer-label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 38px;
    color: rgb(71, 55, 45);
    -unity-text-outline-width: 0;
    margin-left: 0;
    margin-right: 0;
}

.timer-line {
    width: 100%;
    height: 10px;
    border-radius: 5px;
    background-color: rgba(71, 55, 45, 0.14);
    margin-top: -6px;
}

.timer-line__fill {
    height: 10px;
    border-radius: 5px;
    background-color: rgb(255, 197, 61);
    transition-property: width;
    transition-duration: 0.18s;
    transition-timing-function: linear;
}

#timer-pill.timer--low #timer-label {
    color: rgb(223, 91, 65);
}

#timer-pill.timer--low .clock-icon {
    background-color: rgb(255, 127, 99);
    border-bottom-color: rgb(223, 91, 65);
}

#timer-pill.timer--low .timer-line__fill {
    background-color: rgb(223, 91, 65);
}

#speed-panel,
#coins-pill,
#delivery-card,
#timer-pill {
    transition-property: scale;
    transition-duration: 0.34s;
    transition-timing-function: ease-out-elastic;
}

/* ============================================================
   Time-up arcade overlay
   ============================================================ */

#time-up-label {
    position: absolute;
    left: 0;
    right: 0;
    top: 37%;
    height: 180px;
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 118px;
    letter-spacing: 0;
    color: rgb(255, 251, 166);
    -unity-text-outline-width: 8px;
    -unity-text-outline-color: rgb(79, 44, 36);
    -unity-text-align: middle-center;
    opacity: 0;
    translate: 0 86px;
    scale: 0.35 0.35;
    rotate: -6deg;
    transition-property: opacity, translate, scale, rotate;
    transition-duration: 0.16s, 0.34s, 0.34s, 0.34s;
    transition-timing-function: ease-out, ease-out-back, ease-out-back, ease-out-back;
}

/* ============================================================
   Pause panel reference pass
   ============================================================ */

#pause-overlay {
    background-color: rgba(34, 28, 24, 0.36);
    align-items: center;
    justify-content: center;
}

#pause-card,
#settings-card {
    width: 398px;
    min-height: 0;
    padding: 36px 34px 30px 34px;
    border-radius: 34px;
    background-color: rgb(245, 247, 251);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.96);
    border-bottom-width: 16px;
    border-bottom-color: rgb(213, 218, 227);
}

#pause-card .menu-card__title,
#settings-card .menu-card__title {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 40px;
    color: rgb(71, 55, 45);
    -unity-text-outline-width: 0;
    -unity-text-align: middle-center;
    margin-bottom: 28px;
}

#pause-card .button-depth--card,
#settings-card .button-depth--card {
    align-self: center;
    width: 304px;
    height: 84px;
    margin-bottom: 14px;
}

#pause-card .button-depth--card .btn,
#settings-card .button-depth--card .btn {
    left: 0;
    right: 0;
    width: auto;
    height: 70px;
    min-height: 70px;
    border-radius: 30px;
    border-width: 0;
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.48);
    padding: 0 20px;
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 36px;
    -unity-text-outline-width: 0;
    -unity-text-align: middle-center;
}

#pause-card .button-depth--card .button-depth__shadow,
#settings-card .button-depth--card .button-depth__shadow {
    top: 12px;
    height: 70px;
    border-radius: 30px;
}

#pause-card .button-depth--green .btn,
#settings-card .button-depth--green .btn {
    background-color: rgb(119, 216, 103);
    color: white;
}

#pause-card .button-depth__shadow--green,
#settings-card .button-depth__shadow--green {
    background-color: rgb(59, 161, 72);
}

#pause-card .button-depth--sky .btn {
    background-color: rgb(111, 195, 239);
    color: white;
}

#pause-card .button-depth__shadow--sky {
    background-color: rgb(74, 158, 204);
}

#pause-card .button-depth--gold .btn {
    background-color: rgb(255, 203, 71);
    color: rgb(71, 55, 45);
}

#pause-card .button-depth__shadow--gold {
    background-color: rgb(216, 169, 51);
}

#pause-card .button-depth--ghost .btn,
#settings-card .button-depth--ghost .btn {
    background-color: rgb(232, 236, 243);
    color: rgb(71, 55, 45);
}

#pause-card .button-depth__shadow--ghost,
#settings-card .button-depth__shadow--ghost {
    background-color: rgb(191, 199, 212);
}

#settings-card {
    width: 430px;
}

#settings-card .settings-row {
    margin-bottom: 12px;
}

#settings-card .settings-row__label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 22px;
    color: rgb(71, 55, 45);
    -unity-text-outline-width: 0;
    margin-bottom: 4px;
}

#settings-card .volume-slider {
    margin-bottom: 8px;
}

#settings-card .volume-slider .unity-base-slider__tracker {
    height: 12px;
    border-radius: 6px;
    background-color: rgb(220, 225, 233);
    border-width: 0;
}

#settings-card .volume-slider .unity-base-slider__dragger {
    width: 36px;
    height: 36px;
    border-radius: 13px;
    background-color: rgb(190, 198, 211);
    border-width: 5px;
    border-color: white;
    margin-top: -18px;
}

/* ============================================================
   Objective banner clarity pass
   ============================================================ */

#banner {
    position: absolute;
    top: 13%;
    left: 5%;
    right: 5%;
    min-height: 124px;
    padding: 18px 36px;
    border-radius: 28px;
    border-width: 8px;
    border-color: rgb(255, 24, 18);
    border-bottom-width: 16px;
    border-bottom-color: rgb(176, 0, 0);
    background-color: rgba(239, 32, 25, 0.88);
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 64px;
    letter-spacing: 0;
    color: white;
    -unity-text-outline-width: 4px;
    -unity-text-outline-color: rgb(85, 36, 30);
    -unity-text-align: middle-center;
    opacity: 0;
    translate: 0 92px;
    scale: 0.18 0.18;
    rotate: -10deg;
    transition-property: opacity, translate, scale, rotate;
    transition-duration: 0.08s, 0.26s, 0.26s, 0.26s;
    transition-timing-function: ease-out, ease-out-back, ease-out-back, ease-out-back;
}

#banner.banner--show {
    opacity: 1;
    translate: 0 0;
    scale: 1 1;
    rotate: 0deg;
}

#pickup-banner,
#deliver-banner,
#exploded-banner {
    position: absolute;
    top: 110px;
    left: 0;
    right: 0;
    height: 365px;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    opacity: 0;
    translate: 0 92px;
    scale: 0.18 0.18;
    rotate: -10deg;
    transition-property: opacity, translate, scale, rotate;
    transition-duration: 0.08s, 0.26s, 0.26s, 0.26s;
    transition-timing-function: ease-out, ease-out-back, ease-out-back, ease-out-back;
}

#pickup-banner-image,
#deliver-banner-image,
#exploded-banner-image {
    width: 1092px;
    height: 365px;
    -unity-background-scale-mode: scale-to-fit;
}

#pickup-banner-image {
    background-image: url("../../deliver.png");
}

#deliver-banner-image {
    background-image: url("../../deliverthepackage.png");
}

#exploded-banner-image {
    background-image: url("../../packageexploded.png");
}

#pickup-banner.banner--show,
#deliver-banner.banner--show,
#exploded-banner.banner--show {
    opacity: 1;
    translate: 0 0;
    scale: 1 1;
    rotate: 0deg;
}

/* ============================================================
   Main menu sound panel reference pass
   ============================================================ */

#menu-settings-overlay {
    background-color: rgba(34, 28, 24, 0.36);
    align-items: center;
    justify-content: center;
}

#menu-settings-card {
    width: 430px;
    min-height: 0;
    padding: 36px 34px 30px 34px;
    border-radius: 34px;
    background-color: rgb(245, 247, 251);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.96);
    border-bottom-width: 16px;
    border-bottom-color: rgb(213, 218, 227);
}

#menu-settings-card .menu-card__title {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 40px;
    color: rgb(71, 55, 45);
    -unity-text-outline-width: 0;
    -unity-text-align: middle-center;
    margin-bottom: 28px;
}

#menu-settings-card .settings-row {
    margin-bottom: 12px;
}

#menu-settings-card .settings-row__label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 22px;
    color: rgb(71, 55, 45);
    -unity-text-outline-width: 0;
    margin-bottom: 4px;
}

#menu-settings-card .volume-slider {
    margin-bottom: 8px;
}

#menu-settings-card .volume-slider .unity-base-slider__tracker {
    height: 12px;
    border-radius: 6px;
    background-color: rgb(220, 225, 233);
    border-width: 0;
}

#menu-settings-card .volume-slider .unity-base-slider__dragger {
    width: 36px;
    height: 36px;
    border-radius: 13px;
    background-color: rgb(190, 198, 211);
    border-width: 5px;
    border-color: white;
    margin-top: -18px;
}

#menu-settings-card .button-depth--card {
    align-self: center;
    width: 304px;
    height: 84px;
    margin-top: 6px;
    margin-bottom: 0;
}

#menu-settings-card .button-depth--card .btn {
    left: 0;
    right: 0;
    width: auto;
    height: 70px;
    min-height: 70px;
    border-radius: 30px;
    border-width: 0;
    border-bottom-width: 2px;
    border-bottom-color: rgba(255, 255, 255, 0.48);
    padding: 0 20px;
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 36px;
    -unity-text-outline-width: 0;
    -unity-text-align: middle-center;
    background-color: rgb(232, 236, 243);
    color: rgb(71, 55, 45);
}

#menu-settings-card .button-depth--card .button-depth__shadow {
    top: 12px;
    height: 70px;
    border-radius: 30px;
    background-color: rgb(191, 199, 212);
}

/* ============================================================
   Shared coin PNG pass
   ============================================================ */

.coin-badge,
.coin-icon {
    background-image: url("../../coin.png");
    -unity-background-scale-mode: scale-to-fit;
    background-color: transparent;
    border-width: 0;
    border-bottom-width: 0;
    border-radius: 0;
}

.coin-badge__ring,
.coin-badge__ray,
.coin-badge__glint,
.coin-icon__inner,
.coin-star {
    display: none;
}

/* ============================================================
   Kids Magazine compact type pass
   ============================================================ */

.btn {
    font-size: 20px;
}

#play-button {
    font-size: 62px;
    padding: 14px 36px;
    flex-direction: row;
    align-items: center;
    justify-content: center;
}

.play-button__icon {
    width: 46px;
    height: 46px;
    margin-right: 24px;
    background-image: url("../Sprites/play-icon.svg");
    -unity-background-scale-mode: scale-to-fit;
    translate: 2px 0;
}

.play-button__label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 62px;
    color: white;
    -unity-text-align: middle-center;
    translate: 0 -1px;
}

#quit-button {
    font-size: 34px;
}

#version-label {
    font-size: 16px;
}

.stat-pill Label,
#coins-label {
    font-size: 30px;
}

.hud-progress-row Label {
    font-size: 16px;
}

#deliveries-label {
    font-size: 18px;
}

.delivery-copy__eyebrow,
.global-timer__eyebrow {
    font-size: 11px;
}

.delivery-copy__target {
    font-size: 24px;
}

#timer-label {
    font-size: 28px;
}

#speed-label {
    font-size: 54px;
}

#speed-unit {
    font-size: 16px;
}

#banner {
    font-size: 46px;
}

#reward-toast {
    font-size: 44px;
}

#time-up-label {
    font-size: 84px;
}

#pause-card .menu-card__title,
#settings-card .menu-card__title,
#menu-settings-card .menu-card__title {
    font-size: 30px;
}

#pause-card .button-depth--card .btn,
#settings-card .button-depth--card .btn,
#menu-settings-card .button-depth--card .btn {
    font-size: 26px;
}

#settings-card .settings-row__label,
#menu-settings-card .settings-row__label {
    font-size: 16px;
}

/* ============================================================
   Blue arcade HUD reference pass
   ============================================================ */

#safe-area {
    padding: 24px 34px;
}

#top-bar {
    min-height: 98px;
    align-items: flex-start;
}

#top-left {
    position: relative;
    width: 190px;
    height: 78px;
    min-height: 78px;
    padding: 8px 18px 8px 66px;
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
    border-radius: 24px;
    background-color: rgb(18, 161, 224);
    border-width: 4px;
    border-color: rgb(194, 241, 255);
    border-bottom-width: 7px;
    border-bottom-color: rgb(0, 103, 174);
}

.button-depth--pause {
    position: absolute;
    left: -4px;
    top: 3px;
    width: 70px;
    height: 76px;
    margin-right: 0;
    margin-bottom: 0;
}

.button-depth__shadow--pause {
    top: 8px;
    height: 64px;
    border-radius: 32px;
    background-color: rgb(176, 104, 21);
}

.button-depth--pause #pause-button {
    width: 64px;
    height: 64px;
    border-radius: 32px;
    background-color: rgb(255, 202, 49);
    border-width: 4px;
    border-color: rgb(255, 239, 109);
    border-bottom-width: 4px;
    border-bottom-color: rgb(213, 139, 23);
}

.pause-bar {
    width: 7px;
    height: 25px;
    border-radius: 4px;
    margin: 0 3px;
    background-color: rgb(61, 72, 126);
}

#coins-pill {
    min-width: 0;
    min-height: 0;
    height: 54px;
    margin: 0;
    padding: 0;
    flex-direction: row;
    align-items: center;
    background-color: transparent;
    border-width: 0;
    border-bottom-width: 0;
    border-radius: 0;
}

#coins-pill .coin-badge {
    width: 42px;
    height: 42px;
    margin-right: 11px;
    flex-shrink: 0;
}

#coins-label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 38px;
    letter-spacing: 0;
    color: white;
    margin-left: 0;
    -unity-text-outline-width: 3px;
    -unity-text-outline-color: rgb(17, 63, 135);
}

#timer-pill {
    position: relative;
    top: auto;
    left: auto;
    right: auto;
    translate: 0 0;
    display: none;
    width: 326px;
    height: 88px;
    min-height: 88px;
    margin-left: 18px;
    margin-right: 18px;
    padding: 8px 18px 8px 82px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    border-radius: 24px;
    background-color: rgb(19, 163, 226);
    border-width: 4px;
    border-color: rgb(194, 241, 255);
    border-bottom-width: 7px;
    border-bottom-color: rgb(0, 103, 174);
}

#timer-pill.timer--visible {
    display: flex;
}

#timer-pill .clock-icon {
    position: absolute;
    left: 8px;
    top: 8px;
    width: 68px;
    height: 68px;
    border-radius: 34px;
    margin-right: 0;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    background-color: rgb(54, 180, 239);
    border-width: 4px;
    border-color: white;
    border-bottom-width: 6px;
    border-bottom-color: rgb(0, 105, 177);
}

.clock-icon__face {
    position: relative;
    width: 50px;
    height: 50px;
    border-radius: 25px;
    align-items: center;
    justify-content: center;
    background-color: rgb(246, 252, 255);
    border-width: 3px;
    border-color: rgb(34, 124, 189);
}

.clock-icon__tick {
    position: absolute;
    width: 4px;
    height: 8px;
    border-radius: 2px;
    background-color: rgb(47, 100, 165);
}

.clock-icon__tick--top {
    left: 50%;
    top: 5px;
    margin-left: -2px;
}

.clock-icon__tick--right {
    right: 5px;
    top: 50%;
    margin-top: -4px;
    rotate: 90deg;
}

.clock-icon__tick--bottom {
    left: 50%;
    bottom: 5px;
    margin-left: -2px;
}

.clock-icon__tick--left {
    left: 5px;
    top: 50%;
    margin-top: -4px;
    rotate: 90deg;
}

#timer-pill .clock-icon__hand {
    position: absolute;
    left: 50%;
    bottom: 50%;
    width: 5px;
    height: 17px;
    margin-left: -2px;
    border-radius: 3px;
    translate: 0 0;
    rotate: 38deg;
    transform-origin: 50% 100%;
    background-color: rgb(47, 77, 141);
}

.clock-icon__pin {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 9px;
    height: 9px;
    margin-left: -4px;
    margin-top: -4px;
    border-radius: 5px;
    background-color: rgb(255, 202, 49);
    border-width: 2px;
    border-color: rgb(47, 77, 141);
}

.global-timer__copy {
    flex-grow: 1;
    min-width: 0;
    justify-content: center;
}

.global-timer__eyebrow {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 12px;
    letter-spacing: 0;
    color: white;
    -unity-text-outline-width: 1.5px;
    -unity-text-outline-color: rgb(17, 63, 135);
    margin-bottom: -6px;
}

#timer-label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 42px;
    letter-spacing: 0;
    color: white;
    -unity-text-outline-width: 3px;
    -unity-text-outline-color: rgb(17, 63, 135);
    margin-left: 0;
    margin-right: 0;
    margin-top: -3px;
}

.timer-line {
    position: relative;
    width: 100%;
    height: 18px;
    border-radius: 9px;
    overflow: hidden;
    margin-top: -4px;
    background-color: rgb(0, 106, 177);
    border-width: 2px;
    border-color: rgb(0, 90, 155);
}

.timer-line__fill {
    position: absolute;
    left: 2px;
    top: 2px;
    height: 12px;
    border-radius: 7px;
    background-color: rgb(255, 202, 49);
    border-width: 2px;
    border-color: rgb(255, 238, 91);
    border-bottom-width: 3px;
    border-bottom-color: rgb(218, 138, 14);
    transition-property: width;
    transition-duration: 0.18s;
    transition-timing-function: linear;
}

.timer-line__divider {
    position: absolute;
    top: 2px;
    width: 4px;
    height: 14px;
    border-radius: 2px;
    background-color: rgb(0, 106, 177);
}

.timer-line__divider--1 {
    left: 20%;
}

.timer-line__divider--2 {
    left: 40%;
}

.timer-line__divider--3 {
    left: 60%;
}

.timer-line__divider--4 {
    left: 80%;
}

#timer-pill.timer--low {
    background-color: rgb(232, 72, 61);
    border-color: rgb(255, 218, 143);
    border-bottom-color: rgb(169, 42, 38);
}

#timer-pill.timer--low #timer-label,
#timer-pill.timer--low .global-timer__eyebrow {
    color: white;
    -unity-text-outline-color: rgb(121, 36, 47);
}

#timer-pill.timer--low .clock-icon {
    background-color: rgb(255, 189, 55);
    border-bottom-color: rgb(183, 82, 34);
}

#timer-pill.timer--low .timer-line {
    background-color: rgb(134, 37, 50);
    border-color: rgb(111, 31, 45);
}

#timer-pill.timer--low .timer-line__fill {
    background-color: rgb(255, 230, 72);
    border-color: rgb(255, 244, 127);
    border-bottom-color: rgb(210, 128, 18);
}

#delivery-card {
    width: 286px;
    height: 88px;
    min-height: 88px;
    padding: 10px 18px;
    border-radius: 24px;
    flex-shrink: 0;
    background-color: rgb(19, 163, 226);
    border-width: 4px;
    border-color: rgb(194, 241, 255);
    border-bottom-width: 7px;
    border-bottom-color: rgb(0, 103, 174);
}

#delivery-card .package-icon--large {
    width: 56px;
    height: 56px;
    border-radius: 18px;
    margin-right: 14px;
    background-color: rgb(255, 202, 49);
    border-bottom-color: rgb(213, 139, 23);
}

.delivery-copy__eyebrow {
    font-size: 11px;
    letter-spacing: 0;
    color: white;
    -unity-text-outline-width: 1.5px;
    -unity-text-outline-color: rgb(17, 63, 135);
}

.delivery-copy__target {
    font-size: 24px;
    letter-spacing: 0;
    color: white;
    -unity-text-outline-width: 2px;
    -unity-text-outline-color: rgb(17, 63, 135);
    margin-top: 0;
}

/* ============================================================
   HUD top-row layout pass
   ============================================================ */

#safe-area {
    padding: 16px 28px;
}

#top-bar {
    min-height: 112px;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
}

#top-left {
    width: 246px;
    height: 96px;
    min-height: 96px;
    padding: 10px 24px 10px 84px;
    border-radius: 28px;
    border-width: 5px;
    border-color: rgb(202, 243, 255);
    border-bottom-width: 8px;
    border-bottom-color: rgb(0, 95, 167);
    background-color: rgb(18, 159, 224);
}

.button-depth--pause {
    left: -5px;
    top: 5px;
    width: 86px;
    height: 90px;
}

.button-depth__shadow--pause {
    top: 10px;
    height: 76px;
    border-radius: 38px;
