/* ============================================================
   Delivery game UI theme — shared by HUD, pause menu, main menu.
   Palette pulled from the game world: sky blue, grass green,
   delivery-van red, package brown, coin gold on a dark blue ink.
   ============================================================ */

.theme {
    --ink: rgb(46, 58, 80);
    --ink-soft: rgb(103, 116, 140);
    --paper: rgb(255, 255, 255);
    --paper-warm: rgb(244, 246, 250);
    --accent: rgb(232, 85, 91);
    --accent-dark: rgb(196, 63, 69);
    --gold: rgb(255, 197, 61);
    --gold-dark: rgb(224, 165, 38);
    --green: rgb(91, 194, 91);
    --green-dark: rgb(70, 163, 70);
    --sky: rgb(111, 195, 239);
    --sky-dark: rgb(74, 158, 204);
    --shadow: rgba(31, 41, 61, 0.18);
    --dim: rgba(23, 32, 51, 0.6);
    --cream: rgb(255, 248, 239);
    --cream-2: rgb(255, 239, 207);
    --warm-ink: rgb(69, 48, 29);
    --warm-muted: rgb(140, 115, 88);
    --coral: rgb(255, 127, 99);
    --coral-dark: rgb(223, 91, 65);
    --glass: rgba(83, 57, 35, 0.82);
    --glass-strong: rgba(67, 47, 31, 0.88);
    --glass-soft: rgba(255, 255, 255, 0.84);

    -unity-font-definition: url("../../Kids Magazine.ttf");
    color: var(--ink);
}

/* ---------- typography ---------- */

.font-display {
    -unity-font-definition: url("../../Kids Magazine.ttf");
}

.font-bold {
    -unity-font-definition: url("../../Kids Magazine.ttf");
}

.font-body {
    -unity-font-definition: url("../../Kids Magazine.ttf");
}

.font-body-strong {
    -unity-font-definition: url("../../Kids Magazine.ttf");
}

/* ---------- generic building blocks ---------- */

.panel {
    background-color: var(--paper);
    border-radius: 20px;
    border-bottom-width: 5px;
    border-bottom-color: var(--shadow);
}

.pill {
    flex-direction: row;
    align-items: center;
    background-color: var(--paper);
    border-radius: 18px;
    padding: 6px 18px 6px 12px;
    border-bottom-width: 4px;
    border-bottom-color: var(--shadow);
}

.btn {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 26px;
    color: white;
    background-color: var(--accent);
    border-radius: 16px;
    border-width: 0;
    border-bottom-width: 5px;
    border-bottom-color: var(--accent-dark);
    padding: 10px 26px;
    -unity-text-align: middle-center;
    transition-property: scale;
    transition-duration: 0.06s;
}

.btn:hover:enabled {
    scale: 1.03 1.03;
}

.btn:active:enabled {
    scale: 0.97 0.97;
    translate: 0 2px;
    border-bottom-width: 3px;
}

.btn--green {
    background-color: var(--green);
    border-bottom-color: var(--green-dark);
}

.btn--sky {
    background-color: var(--sky);
    border-bottom-color: var(--sky-dark);
}

.btn--gold {
    background-color: var(--gold);
    border-bottom-color: var(--gold-dark);
    color: var(--ink);
}

.btn--ghost {
    background-color: var(--paper-warm);
    border-bottom-color: var(--shadow);
    color: var(--ink-soft);
}

/* ============================================================
   HUD
   ============================================================ */

#hud-root {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
}

#safe-area {
    flex-grow: 1;
    justify-content: space-between;
    padding: 18px 22px;
}

/* ---------- top bar ---------- */

#top-bar {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
}

#top-left {
    flex-direction: row;
    align-items: center;
}

.stat-pill Label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 30px;
    color: var(--ink);
    margin-left: 10px;
}

#coins-pill {
    margin-right: 14px;
}

.coin-icon {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    background-color: var(--gold);
    border-width: 3px;
    border-color: var(--gold-dark);
    align-items: center;
    justify-content: center;
}

.coin-icon__inner {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border-width: 3px;
    border-color: var(--gold-dark);
}

.package-icon {
    width: 32px;
    height: 30px;
    border-radius: 7px;
    background-color: rgb(205, 145, 84);
    border-bottom-width: 3px;
    border-bottom-color: rgb(164, 110, 58);
    align-items: center;
}

.package-icon__tape {
    width: 8px;
    height: 100%;
    background-color: rgba(255, 248, 232, 0.85);
}

/* ---------- delivery timer ---------- */

#timer-pill {
    position: absolute;
    top: 18px;
    left: 50%;
    translate: -50% 0;
    padding: 8px 24px;
    display: none;
}

#timer-pill.timer--visible {
    display: flex;
}

#timer-label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 34px;
    color: var(--ink);
    margin-left: 12px;
}

#timer-pill.timer--low #timer-label {
    color: var(--accent);
}

.clock-icon {
    width: 30px;
    height: 30px;
    border-radius: 10px;
    background-color: var(--sky);
    border-width: 3px;
    border-color: var(--sky-dark);
    align-items: center;
    justify-content: center;
}

.clock-icon__hand {
    width: 4px;
    height: 9px;
    background-color: white;
    border-radius: 2px;
    translate: 0 -3px;
}

/* ---------- pause button ---------- */

#pause-button {
    width: 58px;
    height: 58px;
    border-radius: 16px;
    background-color: rgb(46, 58, 80);
    border-width: 0;
    border-bottom-width: 4px;
    border-bottom-color: rgba(23, 32, 51, 0.6);
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition-property: scale;
    transition-duration: 0.06s;
}

#pause-button:hover:enabled {
    scale: 1.06 1.06;
}

#pause-button:active:enabled {
    scale: 0.94 0.94;
}

.pause-bar {
    width: 7px;
    height: 24px;
    border-radius: 3px;
    background-color: white;
    margin: 0 3px;
}

/* ---------- banner + reward toast ---------- */

#banner {
    position: absolute;
    top: 22%;
    left: 0;
    right: 0;
    -unity-text-align: middle-center;
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 52px;
    color: white;
    -unity-text-outline-width: 2px;
    -unity-text-outline-color: var(--ink);
    opacity: 0;
    scale: 0.8 0.8;
    transition-property: opacity, scale;
    transition-duration: 0.18s, 0.18s;
}

#banner.banner--show {
    opacity: 1;
    scale: 1 1;
}

#reward-toast {
    position: absolute;
    top: 34%;
    left: 0;
    right: 0;
    -unity-text-align: middle-center;
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 44px;
    color: var(--gold);
    -unity-text-outline-width: 2px;
    -unity-text-outline-color: var(--ink);
    opacity: 0;
    transition-property: opacity, translate;
    transition-duration: 0.25s, 0.25s;
    translate: 0 20px;
}

#reward-toast.toast--show {
    opacity: 1;
    translate: 0 0;
}

/* ---------- bottom bar / speed ---------- */

#bottom-bar {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
}

#speed-panel {
    align-items: center;
    flex-direction: row;
    margin-left: auto;
}

#speed-label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 64px;
    color: white;
    -unity-text-outline-width: 2px;
    -unity-text-outline-color: var(--ink);
}

#speed-unit {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 24px;
    color: white;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: var(--ink);
    margin-left: 8px;
    margin-bottom: 12px;
}

/* ============================================================
   Mobile touch controls (hidden unless root has .is-mobile)
   ============================================================ */

.mobile-controls {
    display: none;
    flex-direction: row;
    align-items: flex-end;
}

.is-mobile .mobile-controls {
    display: flex;
}

.is-mobile #speed-panel {
    position: absolute;
    bottom: 240px;
    right: 24px;
    margin-left: 0;
}

.touch-btn {
    background-color: rgba(255, 255, 255, 0.38);
    border-width: 3px;
    border-color: rgba(46, 58, 80, 0.25);
    align-items: center;
    justify-content: center;
    transition-property: scale, background-color;
    transition-duration: 0.05s, 0.05s;
}

.touch-btn:active {
    scale: 0.94 0.94;
    background-color: rgba(255, 255, 255, 0.6);
}

.steer-btn {
    width: 150px;
    height: 150px;
    border-radius: 24px;
}

#steer-left {
    margin-right: 20px;
}

/* chevron built from two rotated bars; the default points left */
.chevron {
    width: 48px;
    height: 48px;
    justify-content: center;
    align-items: center;
}

.chevron__bar-up {
    position: absolute;
    width: 34px;
    height: 11px;
    border-radius: 5px;
    background-color: white;
    rotate: -45deg;
    translate: 0 -9px;
}

.chevron__bar-down {
    position: absolute;
    width: 34px;
    height: 11px;
    border-radius: 5px;
    background-color: white;
    rotate: 45deg;
    translate: 0 9px;
}

.chevron--right {
    rotate: 180deg;
}

.pedal-label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 26px;
    color: white;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(46, 58, 80, 0.5);
}

#pedal-brake {
    width: 122px;
    height: 150px;
    border-radius: 28px;
    background-color: rgba(232, 85, 91, 0.75);
    border-color: rgba(196, 63, 69, 0.9);
    margin-right: 20px;
}

#pedal-gas {
    width: 122px;
    height: 180px;
    border-radius: 28px;
    background-color: rgba(91, 194, 91, 0.75);
    border-color: rgba(70, 163, 70, 0.9);
}

#handbrake-btn {
    width: 96px;
    height: 96px;
    border-radius: 20px;
    background-color: rgba(255, 197, 61, 0.8);
    border-color: rgba(224, 165, 38, 0.9);
    margin-right: 20px;
    margin-bottom: 26px;
}

#handbrake-btn .pedal-label {
    font-size: 36px;
}

/* ============================================================
   Pause overlay + settings
   ============================================================ */

#pause-overlay {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: var(--dim);
    align-items: center;
    justify-content: center;
    display: none;
}

#pause-overlay.overlay--show {
    display: flex;
}

.menu-card {
    width: 440px;
    background-color: var(--paper);
    border-radius: 26px;
    border-bottom-width: 6px;
    border-bottom-color: rgba(31, 41, 61, 0.35);
    padding: 30px 34px;
}

.menu-card__title {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 42px;
    color: var(--ink);
    -unity-text-align: middle-center;
    margin-bottom: 22px;
}

.menu-card .btn {
    margin-bottom: 12px;
}

/* ---------- sliders ---------- */

.settings-row {
    margin-bottom: 6px;
}

.settings-row__label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 2px;
}

.volume-slider {
    margin: 0 0 10px 0;
}

.volume-slider .unity-base-slider__tracker {
    height: 12px;
    border-radius: 6px;
    background-color: var(--paper-warm);
    border-width: 1px;
    border-color: rgba(46, 58, 80, 0.12);
    margin-top: -6px;
}

.volume-slider .unity-base-slider__dragger {
    width: 28px;
    height: 28px;
    border-radius: 10px;
    background-color: var(--accent);
    border-width: 4px;
    border-color: white;
    margin-top: -14px;
}

/* ============================================================
   Main menu
   ============================================================ */

#menu-root {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: var(--sky);
    align-items: center;
    justify-content: center;
}

.menu-ground {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 22%;
    background-color: rgb(126, 203, 79);
}

.menu-road {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 6%;
    height: 9%;
    background-color: rgb(62, 68, 82);
    flex-direction: row;
    align-items: center;
    justify-content: space-around;
}

.menu-road__dash {
    width: 60px;
    height: 8px;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.85);
}

.menu-cloud {
    position: absolute;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 18px;
}

#game-title {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 96px;
    color: white;
    -unity-text-outline-width: 3px;
    -unity-text-outline-color: var(--ink);
    -unity-text-align: middle-center;
    margin-bottom: 8px;
}

#game-subtitle {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 28px;
    color: rgba(255, 255, 255, 0.95);
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: var(--ink);
    -unity-text-align: middle-center;
    margin-bottom: 40px;
}

#menu-buttons {
    width: 340px;
}

#play-button {
    font-size: 36px;
    padding: 16px 26px;
}

#version-label {
    position: absolute;
    bottom: 10px;
    right: 16px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 14px;
}

/* ============================================================
   Prototype pass: warm arcade HUD + 3D menu overlay
   ============================================================ */

.pill,
.top-pill,
.hud-progress,
#delivery-card,
#speed-panel {
    background-color: var(--glass);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.18);
    border-bottom-width: 6px;
    border-bottom-color: rgba(47, 30, 15, 0.22);
}

.btn {
    border-radius: 24px;
    min-height: 56px;
    padding: 10px 18px;
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 24px;
    letter-spacing: 0;
}

.btn--green {
    background-color: rgb(121, 216, 111);
    border-bottom-color: rgb(74, 174, 74);
    color: white;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(74, 174, 74, 0.8);
}

.btn--sky {
    background-color: rgb(115, 206, 255);
    border-bottom-color: rgb(72, 172, 223);
}

.btn--gold {
    background-color: rgb(255, 216, 96);
    border-bottom-color: rgb(216, 169, 51);
    color: var(--warm-ink);
}

.btn--ghost {
    background-color: var(--glass-soft);
    border-bottom-color: rgba(111, 77, 39, 0.14);
    color: rgb(106, 68, 39);
    -unity-text-outline-width: 0;
    font-size: 14px;
}

.btn--wide {
    width: 100%;
}

/* ---------- refreshed HUD layout ---------- */

#safe-area {
    padding: 14px 16px;
}

#top-bar {
    position: relative;
    min-height: 86px;
}

#top-left {
    position: absolute;
    left: 0;
    top: 0;
    flex-direction: row;
    align-items: center;
}

#pause-button {
    width: 44px;
    height: 44px;
    border-radius: 18px;
    background-color: var(--glass-strong);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.16);
    border-bottom-width: 5px;
    border-bottom-color: rgba(47, 30, 15, 0.24);
    margin-right: 8px;
}

.pause-bar {
    width: 5px;
    height: 18px;
    margin: 0 2px;
}

#coins-pill {
    min-height: 44px;
    padding: 8px 14px;
    margin-right: 0;
}

.stat-pill Label {
    font-size: 18px;
    color: white;
    margin-left: 8px;
}

.coin-icon {
    width: 26px;
    height: 26px;
    border-radius: 10px;
    border-width: 0;
    border-bottom-width: 3px;
    background-color: var(--gold);
    border-bottom-color: var(--gold-dark);
}

.coin-icon__inner {
    width: 12px;
    height: 12px;
    border-width: 2px;
    border-color: rgba(120, 75, 18, 0.35);
}

#deliveries-pill {
    position: absolute;
    top: 0;
    left: 50%;
    translate: -50% 0;
}

.hud-progress {
    width: 190px;
    min-height: 44px;
    border-radius: 18px;
    padding: 8px 12px;
}

.hud-progress-row {
    flex-direction: row;
    justify-content: space-between;
    margin-bottom: 4px;
}

.hud-progress-row Label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 10px;
    color: rgba(255, 255, 255, 0.74);
    -unity-text-align: middle-left;
}

#deliveries-label {
    color: white;
}

.track {
    height: 8px;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.16);
}

.track__fill {
    width: 58%;
    height: 8px;
    border-radius: 4px;
    background-color: var(--green);
}

#delivery-card {
    position: absolute;
    top: 0;
    right: 0;
    width: 214px;
    min-height: 76px;
    border-radius: 24px;
    padding: 12px 13px;
    flex-direction: row;
    align-items: center;
}

.package-icon {
    border-width: 0;
}

.package-icon--large {
    width: 48px;
    height: 48px;
    border-radius: 17px;
    background-color: var(--gold);
    border-bottom-width: 4px;
    border-bottom-color: var(--gold-dark);
    margin-right: 10px;
    align-items: center;
    justify-content: center;
}

.package-icon__tape {
    width: 6px;
    height: 100%;
    background-color: rgba(120, 75, 18, 0.25);
}

.delivery-copy {
    flex-grow: 1;
}

.delivery-copy__eyebrow {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 9px;
    color: rgba(255, 255, 255, 0.56);
}

.delivery-copy__target {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 15px;
    color: white;
    margin-top: -2px;
}

#timer-pill {
    position: relative;
    top: auto;
    left: auto;
    translate: 0 0;
    display: none;
    background-color: transparent;
    border-width: 0;
    border-bottom-width: 0;
    padding: 2px 0 0 0;
    margin-top: 2px;
    flex-direction: row;
}

#timer-pill.timer--visible {
    display: flex;
}

#timer-label {
    font-size: 13px;
    color: var(--gold);
    margin-left: 6px;
    margin-right: 6px;
}

.clock-icon {
    width: 18px;
    height: 18px;
    border-width: 2px;
}

.clock-icon__hand {
    width: 3px;
    height: 6px;
    translate: 0 -2px;
}

.timer-line {
    flex-grow: 1;
    height: 6px;
    border-radius: 3px;
    background-color: rgba(255, 255, 255, 0.16);
    align-self: center;
}

.timer-line__fill {
    width: 66%;
    height: 6px;
    border-radius: 3px;
    background-color: var(--gold);
}

#bottom-bar {
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
}

#speed-panel {
    min-width: 148px;
    min-height: 66px;
    border-radius: 26px;
    padding: 8px 16px 8px 10px;
    margin-left: 0;
    flex-direction: row;
    align-items: center;
}

.gauge {
    width: 58px;
    height: 58px;
    border-radius: 16px;
    border-width: 7px;
    border-color: rgba(121, 216, 111, 0.95);
    background-color: rgba(20, 14, 10, 0.28);
    margin-right: 12px;
    align-items: center;
    justify-content: center;
}

.needle {
    width: 4px;
    height: 24px;
    border-radius: 2px;
    background-color: white;
    rotate: -28deg;
    translate: 6px -3px;
}

#speed-label {
    font-size: 28px;
    color: white;
    -unity-text-outline-width: 0;
}

#speed-unit {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.74);
    -unity-text-outline-width: 0;
    margin-left: 8px;
    margin-bottom: 2px;
}

#banner {
    top: 25%;
    font-size: 48px;
}

#reward-toast {
    top: 38%;
}

.touch-btn {
    background-color: var(--glass);
    border-color: rgba(255, 255, 255, 0.16);
}

.control-btn,
#pedal-brake,
#pedal-gas,
#handbrake-btn {
    border-bottom-width: 5px;
    border-bottom-color: rgba(47, 30, 15, 0.24);
}

/* ---------- refreshed menu overlay ---------- */

#menu-root {
    background-color: rgba(0, 0, 0, 0);
    align-items: stretch;
    justify-content: flex-start;
}

.menu-vignette {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(45, 30, 17, 0.16);
}

.menu-top-row {
    position: absolute;
    left: 18px;
    top: 18px;
    right: 18px;
    flex-direction: row;
    justify-content: space-between;
}

.top-pill {
    min-height: 40px;
    border-radius: 18px;
    padding: 8px 14px;
    flex-direction: row;
    align-items: center;
}

.top-pill Label {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 18px;
    color: white;
    margin-left: 8px;
}

.soft-icon {
    width: 26px;
    height: 26px;
    border-radius: 10px;
    background-color: var(--gold);
    border-bottom-width: 3px;
    border-bottom-color: var(--gold-dark);
}

.soft-icon--star {
    border-radius: 12px;
}

.icon-btn {
    width: 42px;
    height: 42px;
    border-radius: 16px;
    padding: 0;
    background-color: var(--glass-soft);
    border-width: 0;
    border-bottom-width: 5px;
    border-bottom-color: rgba(80, 52, 27, 0.12);
    align-items: center;
    justify-content: center;
}

.gear-icon {
    width: 22px;
    height: 22px;
    border-radius: 12px;
    border-width: 5px;
    border-color: var(--warm-ink);
    align-items: center;
    justify-content: center;
}

.gear-icon__dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    background-color: var(--warm-ink);
}

.title-card {
    position: absolute;
    left: 50%;
    top: 28px;
    translate: -50% 0;
    width: 420px;
    align-items: center;
}

.eyebrow {
    width: 178px;
    padding: 7px 14px;
    margin-bottom: 10px;
    border-radius: 14px;
    background-color: rgba(255, 255, 255, 0.86);
    color: rgb(143, 93, 47);
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 10px;
    -unity-text-align: middle-center;
}

#game-title {
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 64px;
    color: white;
    -unity-text-outline-width: 0;
    -unity-text-align: middle-center;
    margin-bottom: 0;
}

#game-subtitle {
    width: 180px;
    padding: 7px 14px;
    margin-top: 12px;
    margin-bottom: 0;
    border-radius: 14px;
    background-color: rgba(255, 255, 255, 0.78);
    color: rgb(106, 68, 39);
    -unity-font-definition: url("../../Kids Magazine.ttf");
    font-size: 12px;
    -unity-text-outline-width: 0;
}

#menu-buttons {
    position: absolute;
    right: 42px;
    bottom: 54px;
    width: 230px;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
}

#menu-buttons .btn {
    margin-bottom: 10px;
}

#play-button {
    width: 100%;
    font-size: 28px;
    padding: 12px 18px;
}

#garage-button,
#shop-button {
    width: 110px;
}

#quit-button {
    width: 100%;
}

#version-label {
    bottom: 12px;
    right: 16px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 13px;
}

